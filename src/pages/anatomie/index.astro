---
// EviWsMed V2 — Anatomische Visualisierung
import '../../styles/global.css';
---

<!DOCTYPE html>

<html class="light" lang="de"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&amp;family=Inter:wght@300;400;500;600;700&amp;family=DM+Mono&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              "tertiary-container": "#223f33",
              "outline-variant": "#dac0c1",
              "inverse-primary": "#ffb2b8",
              "on-secondary-container": "#785c23",
              "surface-variant": "#e7e2da",
              "surface-container-highest": "#e7e2da",
              "primary-fixed-dim": "#ffb2b8",
              "on-secondary-fixed": "#261900",
              "surface-container-high": "#ece8e0",
              "on-tertiary": "#ffffff",
              "secondary": "#765a21",
              "surface-tint": "#9a414d",
              "primary-container": "#6b1d2a",
              "outline": "#877273",
              "on-surface": "#1d1c17",
              "error-container": "#ffdad6",
              "on-primary-fixed": "#40000f",
              "surface-container": "#f2ede5",
              "on-secondary": "#ffffff",
              "error": "#ba1a1a",
              "on-primary-fixed-variant": "#7c2a36",
              "background": "#1A1A1F",
              "surface-dim": "#ded9d2",
              "on-background": "#E2DCD2",
              "secondary-container": "#fed892",
              "on-tertiary-fixed": "#022016",
              "on-surface-variant": "#554243",
              "surface": "#1A1A1F",
              "inverse-surface": "#32302b",
              "tertiary": "#0b291f",
              "primary-fixed": "#ffdadb",
              "tertiary-fixed-dim": "#adcebe",
              "secondary-fixed": "#ffdea4",
              "primary": "#4d0516",
              "on-tertiary-container": "#8baa9b",
              "on-secondary-fixed-variant": "#5b4309",
              "on-primary": "#ffffff",
              "on-error": "#ffffff",
              "on-primary-container": "#ef848f",
              "on-tertiary-fixed-variant": "#304d40",
              "surface-container-low": "#242429",
              "inverse-on-surface": "#f5f0e8",
              "secondary-fixed-dim": "#e6c17e",
              "tertiary-fixed": "#c9ead9",
              "surface-container-lowest": "#2C2C32",
              "surface-bright": "#1A1A1F",
              "on-error-container": "#93000a"
            },
            fontFamily: {
              "headline": ["DM Serif Display", "serif"],
              "body": ["Inter", "sans-serif"],
              "label": ["Inter", "sans-serif"],
              "data": ["DM Mono", "monospace"]
            },
            borderRadius: {"DEFAULT": "0.125rem", "lg": "0.25rem", "xl": "0.5rem", "full": "0.75rem"},
          },
        },
      }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
        }
        .glass-panel {
            background: rgba(44, 44, 50, 0.4);
            backdrop-filter: blur(25px);
            -webkit-backdrop-filter: blur(25px);
        }
        .editorial-grid {
            display: grid;
            grid-template-columns: 1fr 2fr;
            gap: 4rem;
        }
        @media (max-width: 1024px) {
            .editorial-grid {
                grid-template-columns: 1fr;
                gap: 2rem;
            }
        }
    </style>
</head>
<body class="bg-background text-on-background font-body selection:bg-secondary/30">
<!-- TopNavBar from JSON Mapping -->
<nav class="fixed top-0 w-full z-50 flex justify-between items-center px-8 py-4 w-full bg-stone-900/60 backdrop-blur-xl shadow-[0_8px_30px_rgb(0,0,0,0.12)]">
<div class="text-2xl font-headline italic tracking-tight text-stone-100">Clinical Curator</div>
<div class="hidden md:flex items-center space-x-8">
<a class="text-stone-400 font-normal hover:text-rose-500 transition-colors duration-400 text-sm tracking-wide" href="#">Journals</a>
<a class="text-stone-50 font-medium border-b border-rose-900 hover:text-rose-500 transition-colors duration-400 text-sm tracking-wide" href="#">Archives</a>
<a class="text-stone-400 font-normal hover:text-rose-500 transition-colors duration-400 text-sm tracking-wide" href="#">Experts</a>
<a class="text-stone-400 font-normal hover:text-rose-500 transition-colors duration-400 text-sm tracking-wide" href="#">About</a>
</div>
<div class="flex items-center space-x-6">
<span class="material-symbols-outlined text-stone-400 cursor-pointer hover:text-stone-50">dark_mode</span>
<span class="material-symbols-outlined text-stone-400 cursor-pointer hover:text-stone-50">account_circle</span>
</div>
<button id="dark-mode-toggle" class="p-2 rounded-full hover:bg-surface-container transition-colors ml-4" aria-label="Dark Mode"><span class="material-symbols-outlined">dark_mode</span></button></nav>
<!-- SideNavBar from JSON Mapping -->
<aside class="h-screen w-72 fixed left-0 top-0 hidden lg:flex flex-col p-6 border-r border-stone-800/20 bg-stone-950 pt-24">
<div class="mb-12">
<h3 class="font-headline text-xl text-stone-100">Medical Knowledge</h3>
<p class="text-stone-500 text-xs uppercase tracking-widest mt-1">Curated Insights</p>
</div>
<nav class="flex-1 space-y-2">
<div class="flex items-center px-4 py-3 text-stone-500 hover:text-stone-200 hover:bg-stone-900/30 transition-all duration-400 rounded-lg group cursor-pointer">
<span class="material-symbols-outlined mr-3">monitor_heart</span>
<span class="text-sm font-sans tracking-wide">Cardiology</span>
</div>
<div class="flex items-center px-4 py-3 text-stone-500 hover:text-stone-200 hover:bg-stone-900/30 transition-all duration-400 rounded-lg group cursor-pointer">
<span class="material-symbols-outlined mr-3">psychology</span>
<span class="text-sm font-sans tracking-wide">Neurology</span>
</div>
<div class="flex items-center px-4 py-3 text-stone-500 hover:text-stone-200 hover:bg-stone-900/30 transition-all duration-400 rounded-lg group cursor-pointer">
<span class="material-symbols-outlined mr-3">stethoscope</span>
<span class="text-sm font-sans tracking-wide">Oncology</span>
</div>
<div class="flex items-center px-4 py-3 text-stone-500 hover:text-stone-200 hover:bg-stone-900/30 transition-all duration-400 rounded-lg group cursor-pointer">
<span class="material-symbols-outlined mr-3">child_care</span>
<span class="text-sm font-sans tracking-wide">Pediatrics</span>
</div>
<div class="flex items-center px-4 py-3 text-rose-500 font-bold bg-stone-900/50 rounded-lg translate-x-1 duration-400 cursor-pointer">
<span class="material-symbols-outlined mr-3">settings_overscan</span>
<span class="text-sm font-sans tracking-wide">Radiology</span>
</div>
<div class="flex items-center px-4 py-3 text-stone-500 hover:text-stone-200 hover:bg-stone-900/30 transition-all duration-400 rounded-lg group cursor-pointer">
<span class="material-symbols-outlined mr-3">genetics</span>
<span class="text-sm font-sans tracking-wide">Genetics</span>
</div>
<button id="dark-mode-toggle" class="p-2 rounded-full hover:bg-surface-container transition-colors ml-4" aria-label="Dark Mode"><span class="material-symbols-outlined">dark_mode</span></button></nav>
<div class="mt-auto pt-6 border-t border-stone-800/20 space-y-4">
<button class="w-full py-3 bg-primary-container text-on-primary text-[10px] font-bold uppercase tracking-widest rounded-full hover:bg-primary transition-colors duration-400">
                Subscribe to Journals
            </button>
<div class="flex flex-col space-y-2 px-4">
<div class="flex items-center text-stone-600 text-xs hover:text-stone-200 cursor-pointer">
<span class="material-symbols-outlined text-sm mr-2">settings</span> Settings
                </div>
<div class="flex items-center text-stone-600 text-xs hover:text-stone-200 cursor-pointer">
<span class="material-symbols-outlined text-sm mr-2">help</span> Support
                </div>
</div>
</div>
</aside>
<main class="lg:ml-72 pt-32 pb-24 px-8 md:px-16 max-w-7xl mx-auto">
<!-- Hero Section / Editorial Header -->
<header class="mb-24 flex flex-col md:flex-row justify-between items-end gap-8">
<div class="max-w-2xl">
<span class="text-secondary font-label text-xs uppercase tracking-[0.3em] mb-4 block">Visualisierung &amp; Analyse</span>
<h1 class="text-6xl md:text-8xl font-headline leading-[0.9] text-stone-100">Anatomische Visualisierung</h1>
<p class="mt-8 text-lg font-body text-stone-400 leading-relaxed max-w-lg">
                    Eine detaillierte Kartierung der Wirbelsäulensegmente. Unsere kuratierte Ansicht kombiniert radiologische Präzision mit haptischer Ästhetik.
                </p>
</div>
<div class="flex flex-col items-end">
<div class="font-data text-4xl text-secondary mb-2">01 — 04</div>
<div class="h-px w-32 bg-stone-800"></div>
</div>
</header>
<!-- Main Visualization Content -->
<div class="editorial-grid items-center mb-32">
<!-- Left: Spine Illustration Overlay Space -->
<div class="relative group aspect-[3/4] rounded-xl overflow-hidden glass-panel flex items-center justify-center p-12">
<div class="absolute inset-0 bg-gradient-to-b from-stone-900/0 via-stone-900/20 to-stone-900/80 pointer-events-none"></div>
<img alt="Anatomical spine visualization" class="w-full h-full object-cover opacity-40 mix-blend-luminosity filter grayscale contrast-125" data-alt="Detailed monochrome medical scan of a human spine" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAr5oK6Q_HBJXW7TQ37TBXEWbKXIfivugEHkgqGgOv04KbdyzCljv07kl4B3syPG1laUaB3oo6rFZmayYZRQqkpQj6-ZMDdLLWnXfpbrIvNsRe4fUPF8t1TDZXENJTa5zVegNskT1_xnIDqI0W4rnkifLSCOH6ZXO5WDWWoP05NF2UcoOY0HgXbZI9AGnB9xbpChhnIDkudRIhY6cbRZ4wQVlWZE1JjuLkJxcs7ZnK0l7N8mYAAm4TMLY5z21-tzImEvsbkOWhs9zU"/>
<div class="absolute bottom-8 left-8 right-8">
<div class="font-data text-xs text-secondary/60 mb-2 uppercase tracking-widest">Digital Twin Mapping</div>
<div class="text-stone-100 font-headline text-2xl">Vollständiger Scan</div>
</div>
</div>
<!-- Right: 4-Card Spine Region Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
<!-- Card 1: Cervical -->
<div class="glass-panel p-8 rounded-xl flex flex-col justify-between hover:scale-[1.02] transition-transform duration-500 group">
<div>
<span class="material-symbols-outlined text-rose-500 text-3xl mb-6 block group-hover:rotate-12 transition-transform duration-500">architecture</span>
<h3 class="font-headline text-2xl text-stone-100 mb-2">Cervical</h3>
<p class="text-stone-400 text-sm leading-relaxed">C1 - C7: Die obere Wirbelsäule, verantwortlich für Mobilität und neuronale Versorgung.</p>
</div>
<div class="mt-8 font-data text-xs text-secondary tracking-widest">S_01 - S_07</div>
</div>
<!-- Card 2: Thoracic -->
<div class="glass-panel p-8 rounded-xl flex flex-col justify-between hover:scale-[1.02] transition-transform duration-500 group">
<div>
<span class="material-symbols-outlined text-rose-500 text-3xl mb-6 block group-hover:rotate-12 transition-transform duration-500">grid_guides</span>
<h3 class="font-headline text-2xl text-stone-100 mb-2">Thoracic</h3>
<p class="text-stone-400 text-sm leading-relaxed">T1 - T12: Das stabilisierende Zentrum, Schutz für vitale Organe und Atembewegung.</p>
</div>
<div class="mt-8 font-data text-xs text-secondary tracking-widest">S_08 - S_19</div>
</div>
<!-- Card 3: Lumbar -->
<div class="glass-panel p-8 rounded-xl flex flex-col justify-between hover:scale-[1.02] transition-transform duration-500 group">
<div>
<span class="material-symbols-outlined text-rose-500 text-3xl mb-6 block group-hover:rotate-12 transition-transform duration-500">layers</span>
<h3 class="font-headline text-2xl text-stone-100 mb-2">Lumbar</h3>
<p class="text-stone-400 text-sm leading-relaxed">L1 - L5: Die Hauptlastträger, entscheidend für Körperhaltung und Kraftübertragung.</p>
</div>
<div class="mt-8 font-data text-xs text-secondary tracking-widest">S_20 - S_24</div>
</div>
<!-- Card 4: Sacral -->
<div class="glass-panel p-8 rounded-xl flex flex-col justify-between hover:scale-[1.02] transition-transform duration-500 group">
<div>
<span class="material-symbols-outlined text-rose-500 text-3xl mb-6 block group-hover:rotate-12 transition-transform duration-500">foundation</span>
<h3 class="font-headline text-2xl text-stone-100 mb-2">Sacral</h3>
<p class="text-stone-400 text-sm leading-relaxed">S1 - S5: Das anatomische Fundament, Verbindung zum Becken und Unterkörper.</p>
</div>
<div class="mt-8 font-data text-xs text-secondary tracking-widest">S_25 - S_30</div>
</div>
</div>
</div>
<!-- Stats / At a Glance Row -->
<section class="mb-32">
<div class="mb-12 flex items-center gap-4">
<h2 class="font-headline text-3xl text-stone-100">Patientenmetriken</h2>
<div class="h-px flex-1 bg-stone-800/30"></div>
</div>
<div class="grid grid-cols-2 md:grid-cols-4 gap-12">
<div class="flex flex-col">
<span class="text-stone-500 text-[10px] uppercase tracking-widest mb-2">Knochendichte</span>
<span class="font-data text-3xl text-stone-100">1.28 <span class="text-sm text-secondary">g/cm²</span></span>
</div>
<div class="flex flex-col">
<span class="text-stone-500 text-[10px] uppercase tracking-widest mb-2">Wirbelanzahl</span>
<span class="font-data text-3xl text-stone-100">33 <span class="text-sm text-secondary">SEG</span></span>
</div>
<div class="flex flex-col">
<span class="text-stone-500 text-[10px] uppercase tracking-widest mb-2">Kompression</span>
<span class="font-data text-3xl text-stone-100">0.04 <span class="text-sm text-secondary">MPa</span></span>
</div>
<div class="flex flex-col">
<span class="text-stone-500 text-[10px] uppercase tracking-widest mb-2">Ausrichtung</span>
<span class="font-data text-3xl text-stone-100">98.2 <span class="text-sm text-secondary">%</span></span>
</div>
</div>
</section>
</main>
<!-- Footer from JSON Mapping -->
<footer class="w-full py-12 px-8 flex flex-col md:flex-row justify-between items-center border-t border-stone-800/30 bg-stone-950">
<div class="font-headline text-lg text-stone-300 mb-6 md:mb-0">The Clinical Curator</div>
<div class="flex flex-wrap justify-center gap-8 mb-8 md:mb-0">
<a class="text-stone-600 font-sans text-xs uppercase tracking-widest hover:text-stone-200 transition-colors duration-400" href="#">Privacy Policy</a>
<a class="text-stone-600 font-sans text-xs uppercase tracking-widest hover:text-stone-200 transition-colors duration-400" href="#">Terms of Service</a>
<a class="text-stone-600 font-sans text-xs uppercase tracking-widest hover:text-stone-200 transition-colors duration-400" href="#">Editorial Guidelines</a>
<a class="text-stone-600 font-sans text-xs uppercase tracking-widest hover:text-stone-200 transition-colors duration-400" href="#">Contact</a>
</div>
<p class="text-stone-600 font-sans text-[10px] uppercase tracking-widest">
            © 2024 The Clinical Curator. All rights reserved.
        </p>
</footer>
<script is:inline>
const toggle=document.getElementById("dark-mode-toggle");
const html=document.documentElement;
const icon=toggle?.querySelector(".material-symbols-outlined");
const savedMode=localStorage.getItem("theme")||"light";
html.classList.remove("light","dark");
html.classList.add(savedMode);
if(icon)icon.textContent=savedMode==="dark"?"light_mode":"dark_mode";
toggle?.addEventListener("click",()=>{
const current=html.classList.contains("dark")?"dark":"light";
const next=current==="dark"?"light":"dark";
html.classList.remove(current);
html.classList.add(next);
localStorage.setItem("theme",next);
if(icon)icon.textContent=next==="dark"?"light_mode":"dark_mode";
});
</script>
</body></html>