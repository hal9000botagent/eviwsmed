---
// EviWsMed V2 — Registrierung Bestätigung
import '../../../styles/global.css';
---

<!DOCTYPE html>

<html class="light" lang="de"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Registration Success | The Clinical Curator</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&amp;family=Inter:wght@400;500;600&amp;family=DM+Mono&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              "secondary-container": "#fed892",
              "primary": "#4d0516",
              "tertiary-fixed-dim": "#adcebe",
              "secondary-fixed-dim": "#e6c17e",
              "on-secondary-fixed": "#261900",
              "surface-dim": "#ded9d2",
              "surface-variant": "#e7e2da",
              "inverse-surface": "#32302b",
              "tertiary": "#0b291f",
              "surface-bright": "#fef9f1",
              "outline": "#877273",
              "error": "#ba1a1a",
              "secondary-fixed": "#ffdea4",
              "surface-tint": "#9a414d",
              "on-tertiary-fixed": "#022016",
              "primary-container": "#6b1d2a",
              "on-surface": "#1d1c17",
              "on-tertiary-fixed-variant": "#304d40",
              "on-primary-fixed": "#40000f",
              "inverse-on-surface": "#f5f0e8",
              "on-primary-container": "#ef848f",
              "primary-fixed": "#ffdadb",
              "on-secondary-container": "#785c23",
              "on-tertiary": "#ffffff",
              "error-container": "#ffdad6",
              "outline-variant": "#dac0c1",
              "on-primary": "#ffffff",
              "tertiary-fixed": "#c9ead9",
              "background": "#fef9f1",
              "surface-container-high": "#ece8e0",
              "on-secondary-fixed-variant": "#5b4309",
              "on-error-container": "#93000a",
              "surface-container-lowest": "#ffffff",
              "on-background": "#1d1c17",
              "secondary": "#765a21",
              "tertiary-container": "#223f33",
              "surface-container-highest": "#e7e2da",
              "surface": "#fef9f1",
              "on-secondary": "#ffffff",
              "on-primary-fixed-variant": "#7c2a36",
              "inverse-primary": "#ffb2b8",
              "surface-container": "#f2ede5",
              "on-error": "#ffffff",
              "on-surface-variant": "#554243",
              "on-tertiary-container": "#8baa9b",
              "surface-container-low": "#f8f3eb",
              "primary-fixed-dim": "#ffb2b8"
            },
            fontFamily: {
              "headline": ["DM Serif Display", "serif"],
              "body": ["Inter", "sans-serif"],
              "label": ["Inter", "sans-serif"],
              "mono": ["DM Mono", "monospace"]
            },
            borderRadius: {"DEFAULT": "0.125rem", "lg": "0.25rem", "xl": "0.5rem", "full": "0.75rem"},
          },
        },
      }
    </script>
<style>
        body {
            background-color: #F5F0E8;
            font-family: 'Inter', sans-serif;
            -webkit-font-smoothing: antialiased;
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
        }
        .glass-panel {
            background: rgba(255, 255, 255, 0.4);
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
        }
        .radial-glow {
            background: radial-gradient(circle at center, rgba(107, 29, 42, 0.08) 0%, rgba(245, 240, 232, 0) 70%);
        }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="flex flex-col min-h-screen text-on-surface overflow-x-hidden">
<!-- Top Navigation Suppression: Standard for focused journey as per mandate -->
<!-- Main Content Canvas -->
<main class="flex-grow flex flex-col items-center justify-center px-8 relative pt-12 pb-32">
<!-- Subtle Background Articulation -->
<div class="absolute inset-0 radial-glow pointer-events-none"></div>
<!-- Success Animation/Icon Container -->
<div class="relative mb-12 flex items-center justify-center">
<!-- Glass Circle Layers -->
<div class="w-32 h-32 rounded-full glass-panel flex items-center justify-center shadow-[0_20px_40px_rgba(107,29,42,0.12)]">
<div class="w-24 h-24 rounded-full bg-primary-container flex items-center justify-center shadow-inner">
<span class="material-symbols-outlined text-surface text-5xl" style="font-variation-settings: 'FILL' 1;">check_circle</span>
</div>
</div>
<!-- Accent Secondary Glow -->
<div class="absolute -z-10 w-48 h-48 bg-secondary-fixed/20 blur-[50px] rounded-full"></div>
</div>
<!-- Editorial Content -->
<div class="text-center space-y-6 max-w-sm">
<p class="font-mono text-[10px] uppercase tracking-[0.2em] text-secondary font-medium">Step 3: Confirmation</p>
<h1 class="font-headline text-4xl leading-tight text-primary-container tracking-tight">
                Willkommen in der Bibliothek der Exzellenz
            </h1>
<p class="font-body text-on-surface-variant leading-[1.8] text-sm px-4">
                Ihr Zugang zur evidenzbasierten Wirbelsäulenmedizin ist nun aktiv. Entdecken Sie kuratierte Protokolle, wissenschaftliche Tiefe und fachliche Exzellenz.
            </p>
</div>
<!-- Action Area -->
<div class="mt-16 w-full max-w-xs space-y-4">
<button class="w-full bg-primary-container text-surface-container-lowest py-4 px-8 rounded-full font-label text-[11px] font-semibold tracking-[0.1em] uppercase transition-all duration-400 active:scale-[0.96] shadow-xl shadow-primary-container/20">
                Zum Dashboard
            </button>
<div class="flex justify-center">
<p class="text-[10px] text-on-surface/40 font-body uppercase tracking-wider">
                    Evidenzbasierte Wirbelsäulenmedizin
                </p>
</div>
</div>
<!-- Secondary Graphic Element -->
<div class="mt-12 opacity-30">
<img alt="Logo Accent" class="w-8 h-8" data-alt="Minimalist clinical crest logo accent" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBFJk_hQkrFo8wpHgnZmJEc0L5taLU0XgNrKE1848wypNDLv4Omicig2Za0nVc_z98Hkk5y8-3E3dkfiZBdY_0OXEJQ8HJi2SXi_gDPOlMlXfXNLhFAZcQJFWB2dLo-Sah-p1TdfxYsgKKOQV3gDAHPgjDcHUmVUqJjHh1ORrkC08COmW_zli0kgC_O_Ega85-TvZxu1kTSrHC2c9VGmKzPnSCsVUSUlpvESveDJOKl2jSB4AAoUJzjVftJubHs1da0Z-HfNcVfIjE"/>
</div>
</main>
<!-- Shared Component: BottomNavBar (Fixed Shell) -->
<nav class="fixed bottom-0 left-0 w-full z-50 bg-[#F5F0E8]/50 dark:bg-[#1A1A1F]/50 backdrop-blur-[30px] rounded-t-[2rem] shadow-[0_-20px_50px_rgba(0,0,0,0.03)] px-4 pb-6 pt-3 flex justify-around items-center">
<!-- JOURNAL Tab -->
<div class="flex flex-col items-center justify-center text-[#2C2C2C]/40 dark:text-[#E2DCD2]/40 hover:opacity-80 transition-opacity duration-400">
<span class="material-symbols-outlined mb-1" data-icon="menu_book">menu_book</span>
<span class="text-[10px] uppercase tracking-[0.05em] font-medium font-body">JOURNAL</span>
</div>
<!-- DIRECTORY Tab -->
<div class="flex flex-col items-center justify-center text-[#2C2C2C]/40 dark:text-[#E2DCD2]/40 hover:opacity-80 transition-opacity duration-400">
<span class="material-symbols-outlined mb-1" data-icon="medical_services">medical_services</span>
<span class="text-[10px] uppercase tracking-[0.05em] font-medium font-body">DIRECTORY</span>
</div>
<!-- CARE Tab -->
<div class="flex flex-col items-center justify-center text-[#2C2C2C]/40 dark:text-[#E2DCD2]/40 hover:opacity-80 transition-opacity duration-400">
<span class="material-symbols-outlined mb-1" data-icon="favorite">favorite</span>
<span class="text-[10px] uppercase tracking-[0.05em] font-medium font-body">CARE</span>
</div>
<!-- PROFILE Tab (Active Context for registration completion) -->
<div class="flex flex-col items-center justify-center bg-[#6B1D2A] text-[#F5F0E8] rounded-full w-12 h-12 mb-1 scale-95 duration-400 cubic-bezier(0.4, 0, 0.2, 1)">
<span class="material-symbols-outlined" data-icon="person">person</span>
</div>
<button id="dark-mode-toggle" class="p-2 rounded-full hover:bg-surface-container transition-colors ml-4" aria-label="Dark Mode"><span class="material-symbols-outlined">dark_mode</span></button></nav>
<!-- Decoration Layer -->
<div class="fixed top-0 left-0 w-full h-full pointer-events-none -z-20">
<div class="absolute top-[10%] -left-[20%] w-[60%] h-[40%] bg-secondary-fixed/5 blur-[120px] rounded-full"></div>
<div class="absolute bottom-[20%] -right-[10%] w-[50%] h-[30%] bg-primary-container/5 blur-[100px] rounded-full"></div>
</div>
<script is:inline>
const toggle=document.getElementById("dark-mode-toggle");
const html=document.documentElement;
const icon=toggle?.querySelector(".material-symbols-outlined");
const savedMode=localStorage.getItem("theme")||"light";
html.classList.remove("light","dark");
html.classList.add(savedMode);
if(icon)icon.textContent=savedMode==="dark"?"light_mode":"dark_mode";
toggle?.addEventListener("click",()=>{
const current=html.classList.contains("dark")?"dark":"light";
const next=current==="dark"?"light":"dark";
html.classList.remove(current);
html.classList.add(next);
localStorage.setItem("theme",next);
if(icon)icon.textContent=next==="dark"?"light_mode":"dark_mode";
});
</script>
</body></html>