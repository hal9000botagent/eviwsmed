---
// EviWsMed V2 — Registrierung Willkommen
import '../../styles/global.css';
---

<!DOCTYPE html>

<html class="light" lang="de"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&amp;family=Inter:wght@400;500;600&amp;family=DM+Mono&amp;family=Newsreader:opsz,wght@6..72,400;500;600&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              "secondary-container": "#fed892",
              "primary": "#4d0516",
              "tertiary-fixed-dim": "#adcebe",
              "secondary-fixed-dim": "#e6c17e",
              "on-secondary-fixed": "#261900",
              "surface-dim": "#ded9d2",
              "surface-variant": "#e7e2da",
              "inverse-surface": "#32302b",
              "tertiary": "#0b291f",
              "surface-bright": "#fef9f1",
              "outline": "#877273",
              "error": "#ba1a1a",
              "secondary-fixed": "#ffdea4",
              "surface-tint": "#9a414d",
              "on-tertiary-fixed": "#022016",
              "primary-container": "#6b1d2a",
              "on-surface": "#1d1c17",
              "on-tertiary-fixed-variant": "#304d40",
              "on-primary-fixed": "#40000f",
              "inverse-on-surface": "#f5f0e8",
              "on-primary-container": "#ef848f",
              "primary-fixed": "#ffdadb",
              "on-secondary-container": "#785c23",
              "on-tertiary": "#ffffff",
              "error-container": "#ffdad6",
              "outline-variant": "#dac0c1",
              "on-primary": "#ffffff",
              "tertiary-fixed": "#c9ead9",
              "background": "#fef9f1",
              "surface-container-high": "#ece8e0",
              "on-secondary-fixed-variant": "#5b4309",
              "on-error-container": "#93000a",
              "surface-container-lowest": "#ffffff",
              "on-background": "#1d1c17",
              "secondary": "#765a21",
              "tertiary-container": "#223f33",
              "surface-container-highest": "#e7e2da",
              "surface": "#fef9f1",
              "on-secondary": "#ffffff",
              "on-primary-fixed-variant": "#7c2a36",
              "inverse-primary": "#ffb2b8",
              "surface-container": "#f2ede5",
              "on-error": "#ffffff",
              "on-surface-variant": "#554243",
              "on-tertiary-container": "#8baa9b",
              "surface-container-low": "#f8f3eb",
              "primary-fixed-dim": "#ffb2b8"
            },
            fontFamily: {
              "headline": ["DM Serif Display", "serif"],
              "body": ["Inter", "sans-serif"],
              "label": ["Inter", "sans-serif"],
              "mono": ["DM Mono", "monospace"]
            },
            borderRadius: {"DEFAULT": "0.125rem", "lg": "0.25rem", "xl": "0.5rem", "full": "9999px"},
          },
        },
      }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.4);
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
        }
        .radial-soul {
            background: radial-gradient(circle at center, rgba(107, 29, 42, 0.08) 0%, transparent 70%);
        }
        .asymmetric-layout {
            padding-left: 10%;
            padding-right: 5%;
        }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-[#F5F0E8] text-on-surface font-body min-h-screen selection:bg-primary/10">
<!-- TopAppBar Shell -->
<header class="fixed top-0 w-full z-50 bg-[#F5F0E8]/60 dark:bg-[#1A1A1F]/60 backdrop-blur-[20px] shadow-[0_40px_60px_-15px_rgba(44,44,44,0.05)] flex justify-between items-center px-6 py-4 w-full">
<div class="flex items-center gap-4">
<span class="material-symbols-outlined text-[#6B1D2A] dark:text-[#E2DCD2]" data-icon="menu">menu</span>
<h1 class="text-lg font-serif tracking-widest text-[#6B1D2A] dark:text-[#E2DCD2]">THE CLINICAL CURATOR</h1>
</div>
<div class="w-10 h-10 rounded-full bg-surface-container-highest flex items-center justify-center">
<span class="material-symbols-outlined text-secondary" data-icon="account_circle">account_circle</span>
</div>
</header>
<main class="pt-28 pb-12 px-6 flex flex-col min-h-screen relative overflow-hidden">
<!-- Background Radial Soul Decor -->
<div class="absolute top-1/4 -right-20 w-80 h-80 radial-soul pointer-events-none"></div>
<div class="absolute bottom-1/4 -left-20 w-96 h-96 radial-soul pointer-events-none"></div>
<!-- Headline Section -->
<section class="mb-12 relative z-10">
<span class="font-mono text-[10px] uppercase tracking-[0.2em] text-secondary mb-4 block">Willkommen</span>
<h2 class="font-headline text-4xl md:text-5xl leading-tight text-primary-container max-w-[90%]">
                Willkommen bei der Kuratierung Ihrer Gesundheit
            </h2>
<p class="mt-6 text-on-surface-variant leading-[1.8] text-sm max-w-[85%]">
                Wählen Sie Ihren Zugangsweg zur evidenzbasierten Wirbelsäulenmedizin. 
                Ein Raum für Präzision, Ruhe und medizinische Exzellenz.
            </p>
</section>
<!-- Selection Cards (Asymmetric Grid) -->
<div class="flex flex-col gap-6 relative z-10">
<!-- Patient Selection Card -->
<button class="group relative text-left outline-none transition-all duration-400 active:scale-[0.98]">
<div class="absolute -inset-2 bg-primary/5 rounded-[2rem] opacity-0 group-hover:opacity-100 transition-opacity duration-400"></div>
<div class="glass-card p-8 rounded-[2rem] shadow-[0_20px_50px_rgba(0,0,0,0.03)] border-none relative overflow-hidden">
<!-- Subtle Interior Glow -->
<div class="absolute -top-10 -right-10 w-32 h-32 bg-primary/5 rounded-full blur-2xl transition-transform group-hover:scale-150 duration-700"></div>
<div class="flex justify-between items-start mb-12">
<div class="w-12 h-12 bg-primary text-on-primary rounded-full flex items-center justify-center">
<span class="material-symbols-outlined" data-icon="person">person</span>
</div>
<span class="font-mono text-[10px] text-secondary tracking-widest">STEP 01/03</span>
</div>
<div>
<h3 class="font-headline text-2xl text-primary-container mb-2">Patient</h3>
<p class="text-xs text-on-surface-variant leading-relaxed opacity-80">
                            Ich suche nach spezialisierter Behandlung und möchte meine Krankenakte verwalten.
                        </p>
</div>
<div class="mt-8 flex items-center gap-2 text-[10px] font-bold tracking-[0.05em] uppercase text-primary">
<span>Konto Erstellen</span>
<span class="material-symbols-outlined text-[16px] transition-transform group-hover:translate-x-1 duration-400" data-icon="arrow_forward">arrow_forward</span>
</div>
</div>
</button>
<!-- Professional Selection Card -->
<button class="group relative text-left outline-none transition-all duration-400 active:scale-[0.98]">
<div class="absolute -inset-2 bg-secondary/5 rounded-[2rem] opacity-0 group-hover:opacity-100 transition-opacity duration-400"></div>
<div class="glass-card p-8 rounded-[2rem] shadow-[0_20px_50px_rgba(0,0,0,0.03)] border-none relative overflow-hidden">
<!-- Subtle Interior Glow -->
<div class="absolute -bottom-10 -left-10 w-32 h-32 bg-secondary/10 rounded-full blur-2xl transition-transform group-hover:scale-150 duration-700"></div>
<div class="flex justify-between items-start mb-12">
<div class="w-12 h-12 bg-secondary text-on-secondary rounded-full flex items-center justify-center">
<span class="material-symbols-outlined" data-icon="medical_services">medical_services</span>
</div>
<span class="font-mono text-[10px] text-secondary tracking-widest">VERIFIED ONLY</span>
</div>
<div>
<h3 class="font-headline text-2xl text-primary-container mb-2">Fachkreis</h3>
<p class="text-xs text-on-surface-variant leading-relaxed opacity-80">
                            Ich bin Mediziner oder Therapeut und möchte auf das klinische Netzwerk zugreifen.
                        </p>
</div>
<div class="mt-8 flex items-center gap-2 text-[10px] font-bold tracking-[0.05em] uppercase text-secondary">
<span>Portal-Login</span>
<span class="material-symbols-outlined text-[16px] transition-transform group-hover:translate-x-1 duration-400" data-icon="lock_open">lock_open</span>
</div>
</div>
</button>
</div>
<!-- Secondary Actions -->
<div class="mt-auto pt-12 flex flex-col items-center gap-6 relative z-10">
<div class="w-8 h-[1px] bg-outline-variant/30"></div>
<p class="text-xs text-on-surface-variant/60 font-body">
                Haben Sie bereits ein Konto? 
                <a class="text-primary font-semibold underline-offset-4 decoration-primary/20 hover:decoration-primary/60 transition-all" href="#">Anmelden</a>
</p>
</div>
</main>
<!-- Visual Polish: Top Gradient Overlay -->
<div class="fixed top-0 inset-x-0 h-32 bg-gradient-to-b from-[#F5F0E8] to-transparent pointer-events-none z-40 opacity-80"></div>
<script is:inline>
const toggle=document.getElementById("dark-mode-toggle");
const html=document.documentElement;
const icon=toggle?.querySelector(".material-symbols-outlined");
const savedMode=localStorage.getItem("theme")||"light";
html.classList.remove("light","dark");
html.classList.add(savedMode);
if(icon)icon.textContent=savedMode==="dark"?"light_mode":"dark_mode";
toggle?.addEventListener("click",()=>{
const current=html.classList.contains("dark")?"dark":"light";
const next=current==="dark"?"light":"dark";
html.classList.remove(current);
html.classList.add(next);
localStorage.setItem("theme",next);
if(icon)icon.textContent=next==="dark"?"light_mode":"dark_mode";
});
</script>
</body></html>