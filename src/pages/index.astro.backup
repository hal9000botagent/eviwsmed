---
// EviWsMed Landing Page — Function Health Polish Pass
const title = 'Evidenzbasierte Wirbelsäulenmedizin';
const description = 'Verständlich. Quellenbasiert. Für Patienten und Fachpersonal.';
const siteUrl = 'https://evidenzbasierte-wirbelsaeulenmedizin.de';
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="icon" type="image/png" href="/favicon.png">
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Cormorant+SC:wght@300;400;500;600&display=swap" rel="stylesheet">
  
  <!-- Schema.org -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "MedicalWebPage",
      "name": "Evidenzbasierte Wirbelsäulenmedizin",
      "url": "https://evidenzbasierte-wirbelsaeulenmedizin.de",
      "description": "Evidenzbasierte Fachartikel und Patienteninformationen zur Wirbelsäulenmedizin",
      "inLanguage": "de",
      "medicalAudience": {
        "@type": "MedicalAudience",
        "audienceType": "Patient"
      },
      "publisher": {
        "@type": "Organization",
        "name": "EviWsMed"
      }
    }
  </script>
  
  <style>
    /* ─── RESET & BASE ─── */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    :root {
      /* Light Mode */
      --bg: #F5F0E8;
      --text: #2C2C2C;
      --text-muted: #6B6155;
      --primary: #6B1D2A;
      --primary-hover: #4a1019;
      --accent: #2D4A3E;
      --gold: #A8884A;
      --border: #D4CBBA;
      --card-bg: #FFFDF7;
      --nav-bg: rgba(245, 240, 232, 0.8);
      --shadow-subtle: 0 2px 12px rgba(0, 0, 0, 0.06);
      --shadow-medium: 0 8px 24px rgba(0, 0, 0, 0.10);
      --shadow-strong: 0 16px 48px rgba(0, 0, 0, 0.14);
    }
    
    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #1A1A1F;
        --text: #E2DCD2;
        --text-muted: #9C9487;
        --primary: #C4586A;
        --primary-hover: #f3d0d6;
        --accent: #5A9E82;
        --gold: #C4A96A;
        --border: #3A3A42;
        --card-bg: #242429;
        --nav-bg: rgba(26, 26, 31, 0.8);
        --shadow-subtle: 0 2px 12px rgba(0, 0, 0, 0.4);
        --shadow-medium: 0 8px 24px rgba(0, 0, 0, 0.5);
        --shadow-strong: 0 16px 48px rgba(0, 0, 0, 0.6);
      }
    }
    
    html {
      scroll-behavior: smooth;
    }
    
    body {
      font-family: 'EB Garamond', Georgia, serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.7;
      font-size: 18px;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }
    
    h1, h2, h3 {
      font-family: 'Playfair Display', Georgia, serif;
      font-weight: 700;
      line-height: 1.2;
      letter-spacing: -0.02em;
    }
    
    h1 {
      font-size: clamp(3rem, 6vw, 5rem);
      letter-spacing: -0.03em;
      line-height: 1.1;
    }
    
    h2 {
      font-size: clamp(2rem, 4.5vw, 3rem);
      margin-bottom: 1.5rem;
      letter-spacing: -0.02em;
      line-height: 1.2;
    }
    
    h3 {
      font-size: clamp(1.3rem, 3vw, 1.8rem);
      font-weight: 400;
      font-style: italic;
    }
    
    p {
      line-height: 1.75;
    }
    
    /* ─── NAVIGATION ─── */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: transparent;
      backdrop-filter: blur(0px);
      border-bottom: 1px solid transparent;
      padding: 1.5rem 0;
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    nav.scrolled {
      background: var(--nav-bg);
      backdrop-filter: blur(12px);
      border-bottom-color: var(--border);
      padding: 1rem 0;
      box-shadow: var(--shadow-subtle);
    }
    
    .nav-container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    
    .logo {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--primary);
      text-decoration: none;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .logo:hover {
      opacity: 0.7;
      transform: translateY(-1px);
    }
    
    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
      font-family: 'Cormorant SC', serif;
      letter-spacing: 0.08em;
    }
    
    .nav-links a {
      color: var(--text);
      text-decoration: none;
      font-weight: 500;
      position: relative;
      transition: color 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .nav-links a::after {
      content: '';
      position: absolute;
      bottom: -4px;
      left: 0;
      width: 0;
      height: 2px;
      background: var(--primary);
      transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .nav-links a:hover {
      color: var(--primary);
    }
    
    .nav-links a:hover::after {
      width: 100%;
    }
    
    .mobile-toggle {
      display: none;
      background: none;
      border: none;
      color: var(--text);
      font-size: 1.5rem;
      cursor: pointer;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .mobile-toggle:hover {
      transform: scale(1.1);
    }
    
    @media (max-width: 768px) {
      .nav-links {
        position: fixed;
        top: 70px;
        left: 0;
        right: 0;
        background: var(--nav-bg);
        backdrop-filter: blur(12px);
        flex-direction: column;
        padding: 2rem;
        gap: 1rem;
        transform: translateY(-150%);
        transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        border-bottom: 1px solid var(--border);
        box-shadow: var(--shadow-medium);
      }
      
      .nav-links.active {
        transform: translateY(0);
      }
      
      .mobile-toggle {
        display: block;
      }
    }
    
    /* ─── HERO ─── */
    .hero {
      min-height: 90vh;
      display: flex;
      align-items: center;
      background: 
        radial-gradient(ellipse at top, rgba(168, 136, 74, 0.06), transparent 60%),
        radial-gradient(ellipse at bottom right, rgba(107, 29, 42, 0.04), transparent 50%),
        linear-gradient(135deg, var(--bg) 0%, var(--card-bg) 50%, var(--bg) 100%);
      position: relative;
      overflow: hidden;
      padding-top: 2rem;
    }
    
    .hero::before {
      content: '';
      position: absolute;
      top: 0;
      right: 0;
      width: 50%;
      height: 100%;
      background: 
        linear-gradient(45deg, transparent 30%, var(--accent) 30%, var(--accent) 31%, transparent 31%),
        linear-gradient(-45deg, transparent 30%, var(--gold) 30%, var(--gold) 31%, transparent 31%);
      opacity: 0.02;
      pointer-events: none;
    }
    
    .hero-content {
      max-width: 1400px;
      margin: 0 auto;
      padding: 5rem 2rem;
      position: relative;
      z-index: 1;
    }
    
    .hero-badge {
      display: inline-block;
      font-family: 'Cormorant SC', serif;
      font-size: 0.85rem;
      letter-spacing: 0.15em;
      color: var(--gold);
      background: rgba(168, 136, 74, 0.08);
      padding: 0.6rem 1.5rem;
      border-radius: 24px;
      margin-bottom: 2rem;
      border: 1px solid var(--gold);
      opacity: 0;
      animation: fadeInUp 0.8s cubic-bezier(0.4, 0, 0.2, 1) 0.2s forwards;
    }
    
    .hero h1 {
      margin-bottom: 1.5rem;
      color: var(--primary);
      opacity: 0;
      animation: fadeInUp 0.8s cubic-bezier(0.4, 0, 0.2, 1) 0.4s forwards;
    }
    
    .hero h1 em {
      font-style: italic;
      display: block;
    }
    
    .hero-subtitle {
      font-size: 1.4rem;
      color: var(--text-muted);
      margin-bottom: 3rem;
      max-width: 700px;
      line-height: 1.9;
      opacity: 0;
      animation: fadeInUp 0.8s cubic-bezier(0.4, 0, 0.2, 1) 0.6s forwards;
      font-weight: 400;
    }
    
    .hero-cta {
      display: inline-block;
      background: var(--primary);
      color: #FFFDF7;
      padding: 1.1rem 2.8rem;
      border-radius: 8px;
      text-decoration: none;
      font-family: 'Cormorant SC', serif;
      letter-spacing: 0.12em;
      font-size: 1.05rem;
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      border: 2px solid var(--primary);
      box-shadow: var(--shadow-subtle);
      opacity: 0;
      animation: fadeInUp 0.8s cubic-bezier(0.4, 0, 0.2, 1) 0.8s forwards;
    }
    
    .hero-cta:hover {
      background: var(--primary-hover);
      border-color: var(--primary-hover);
      transform: translateY(-3px) scale(1.02);
      box-shadow: var(--shadow-medium);
    }
    
    .hero-cta:active {
      transform: translateY(-1px) scale(0.98);
    }
    
    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    
    /* ─── NUMBERED STEPS ─── */
    .steps {
      max-width: 1200px;
      margin: 0 auto;
      padding: 120px 2rem;
      background: 
        linear-gradient(180deg, var(--bg) 0%, transparent 10%, transparent 90%, var(--bg) 100%);
    }
    
    .steps h2 {
      text-align: center;
      margin-bottom: 4rem;
    }
    
    .steps h2 em {
      color: var(--primary);
      font-style: italic;
    }
    
    .steps-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 4rem;
    }
    
    .step {
      text-align: center;
      opacity: 0;
      transform: translateY(30px);
      transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .step.visible {
      opacity: 1;
      transform: translateY(0);
    }
    
    .step-number {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 5rem;
      font-weight: 300;
      color: var(--gold);
      opacity: 0.35;
      margin-bottom: 1.5rem;
      letter-spacing: -0.02em;
      line-height: 1;
    }
    
    .step h3 {
      margin-bottom: 1rem;
      color: var(--primary);
    }
    
    .step p {
      color: var(--text-muted);
      font-size: 1.05rem;
      line-height: 1.7;
    }
    
    /* ─── SCROLLING TICKER ─── */
    .ticker-section {
      background: 
        radial-gradient(ellipse at center, rgba(168, 136, 74, 0.04), transparent 70%),
        linear-gradient(180deg, var(--bg) 0%, var(--card-bg) 50%, var(--bg) 100%);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: 100px 0;
      overflow: hidden;
      margin: 100px 0;
    }
    
    .ticker-section h2 {
      text-align: center;
      margin-bottom: 3rem;
    }
    
    .ticker-wrapper {
      overflow: hidden;
      position: relative;
      margin: 0 auto;
      -webkit-mask-image: linear-gradient(90deg, transparent, black 10%, black 90%, transparent);
      mask-image: linear-gradient(90deg, transparent, black 10%, black 90%, transparent);
    }
    
    .ticker {
      display: flex;
      animation: scroll 45s linear infinite;
      will-change: transform;
    }
    
    .ticker:hover {
      animation-play-state: paused;
    }
    
    .ticker-item {
      flex-shrink: 0;
      padding: 0.9rem 2.5rem;
      margin: 0 1rem;
      background: var(--bg);
      border-radius: 28px;
      border: 1px solid var(--border);
      white-space: nowrap;
      font-family: 'Cormorant SC', serif;
      letter-spacing: 0.06em;
      font-size: 1.05rem;
      box-shadow: var(--shadow-subtle);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .ticker-item:hover {
      transform: scale(1.05);
      box-shadow: var(--shadow-medium);
      border-color: var(--primary);
    }
    
    @keyframes scroll {
      0% {
        transform: translateX(0);
      }
      100% {
        transform: translateX(-50%);
      }
    }
    
    /* ─── CATEGORY CARDS ─── */
    .categories {
      max-width: 1400px;
      margin: 0 auto;
      padding: 120px 2rem;
      background: 
        radial-gradient(ellipse at top left, rgba(45, 74, 62, 0.03), transparent 60%),
        radial-gradient(ellipse at bottom right, rgba(107, 29, 42, 0.03), transparent 60%);
    }
    
    .categories h2 {
      text-align: center;
      margin-bottom: 4rem;
    }
    
    .category-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 2.5rem;
    }
    
    .category-card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 3rem 2.5rem;
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      text-decoration: none;
      color: var(--text);
      box-shadow: var(--shadow-subtle);
      opacity: 0;
      transform: translateY(30px);
      position: relative;
    }
    
    .category-icon {
      width: 48px;
      height: 48px;
      margin-bottom: 1.5rem;
      opacity: 0.8;
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .category-card:hover .category-icon {
      transform: scale(1.15) translateY(-4px);
      opacity: 1;
    }
    
    .category-card.visible {
      opacity: 1;
      transform: translateY(0);
    }
    
    .category-card:hover {
      transform: translateY(-8px) scale(1.01);
      border-color: var(--primary);
      box-shadow: 
        0 12px 36px rgba(107, 29, 42, 0.15),
        0 4px 12px rgba(107, 29, 42, 0.08);
      background: linear-gradient(135deg, var(--card-bg) 0%, var(--bg) 100%);
    }
    
    .category-card h3 {
      color: var(--primary);
      margin-bottom: 1rem;
      transition: color 0.3s ease;
    }
    
    .category-card:hover h3 {
      color: var(--gold);
    }
    
    .category-card > p {
      color: var(--text-muted);
      margin-bottom: 1.2rem;
      line-height: 1.7;
    }
    
    .category-card ul {
      list-style: none;
      margin-top: 1.5rem;
    }
    
    .category-card li {
      color: var(--text-muted);
      padding: 0.5rem 0;
      font-size: 0.95rem;
      transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .category-card li::before {
      content: '→';
      color: var(--gold);
      margin-right: 0.7rem;
      display: inline-block;
      transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .category-card:hover li::before {
      transform: translateX(4px);
    }
    
    /* ─── TRUST SECTION ─── */
    .trust {
      background: 
        radial-gradient(ellipse at top, rgba(168, 136, 74, 0.05), transparent 50%),
        linear-gradient(180deg, var(--card-bg) 0%, var(--bg) 100%);
      border-top: 1px solid var(--border);
      padding: 100px 2rem;
      margin-top: 100px;
    }
    
    .trust-content {
      max-width: 900px;
      margin: 0 auto;
      text-align: center;
    }
    
    .trust h2 {
      margin-bottom: 3rem;
    }
    
    .trust h2 em {
      color: var(--primary);
      font-style: italic;
    }
    
    .trust blockquote {
      font-size: 1.25rem;
      font-style: italic;
      color: var(--text-muted);
      border-left: 3px solid var(--gold);
      padding-left: 2.5rem;
      margin: 2.5rem 0;
      text-align: left;
      line-height: 1.8;
      opacity: 0;
      transform: translateY(30px);
      transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .trust blockquote.visible {
      opacity: 1;
      transform: translateY(0);
    }
    
    .trust cite {
      display: block;
      margin-top: 1.2rem;
      font-size: 0.95rem;
      font-style: normal;
      color: var(--text);
      font-family: 'Cormorant SC', serif;
      letter-spacing: 0.05em;
    }
    
    /* ─── AUTHOR SECTION ─── */
    .author {
      max-width: 1000px;
      margin: 100px auto;
      padding: 0 2rem;
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 4rem;
      align-items: center;
    }
    
    @media (max-width: 768px) {
      .author {
        grid-template-columns: 1fr;
        gap: 2rem;
      }
    }
    
    .author-image {
      width: 100%;
      aspect-ratio: 1;
      background: linear-gradient(135deg, var(--accent) 0%, var(--primary) 100%);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 5rem;
      color: #FFFDF7;
      box-shadow: var(--shadow-medium);
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      opacity: 0;
      transform: scale(0.9);
    }
    
    .author-image.visible {
      opacity: 1;
      transform: scale(1);
    }
    
    .author-image:hover {
      transform: scale(1.05) rotate(2deg);
      box-shadow: var(--shadow-strong);
    }
    
    .author-text {
      opacity: 0;
      transform: translateX(30px);
      transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .author-text.visible {
      opacity: 1;
      transform: translateX(0);
    }
    
    .author h2 {
      margin-bottom: 0.5rem;
    }
    
    .author-title {
      color: var(--text-muted);
      font-size: 1.05rem;
      margin-bottom: 1.8rem;
      font-family: 'Cormorant SC', serif;
      letter-spacing: 0.08em;
    }
    
    .author-text p {
      line-height: 1.8;
    }
    
    /* ─── COMPARISON TABLE ─── */
    .comparison {
      max-width: 1200px;
      margin: 120px auto;
      padding: 0 2rem;
    }
    
    .comparison h2 {
      text-align: center;
      margin-bottom: 4rem;
    }
    
    .comparison h2 em {
      color: var(--primary);
      font-style: italic;
    }
    
    .comparison-table {
      background: var(--card-bg);
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid var(--border);
      box-shadow: var(--shadow-medium);
      opacity: 0;
      transform: translateY(30px);
      transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .comparison-table.visible {
      opacity: 1;
      transform: translateY(0);
    }
    
    .comparison-row {
      display: grid;
      grid-template-columns: 1.5fr 1fr 1fr;
      border-bottom: 1px solid var(--border);
      transition: background 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .comparison-row:last-child {
      border-bottom: none;
    }
    
    .comparison-row:not(:first-child):hover {
      background: var(--bg);
    }
    
    .comparison-header {
      background: var(--primary);
      color: #FFFDF7;
      font-family: 'Cormorant SC', serif;
      letter-spacing: 0.1em;
      text-align: center;
      padding: 1.2rem;
      font-weight: 600;
    }
    
    .comparison-cell {
      padding: 1.5rem;
      border-right: 1px solid var(--border);
      line-height: 1.6;
    }
    
    .comparison-cell:last-child {
      border-right: none;
    }
    
    .check {
      color: var(--accent);
      font-size: 1.8rem;
      text-align: center;
      transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .comparison-row:hover .check {
      transform: scale(1.2);
    }
    
    .cross {
      color: var(--primary);
      font-size: 1.8rem;
      text-align: center;
      opacity: 0.3;
    }
    
    @media (max-width: 768px) {
      .comparison-row {
        grid-template-columns: 2fr 1fr 1fr;
      }
      
      .comparison-cell {
        padding: 1rem;
        font-size: 0.9rem;
      }
    }
    
    /* ─── FOOTER ─── */
    footer {
      background: linear-gradient(180deg, var(--bg) 0%, var(--card-bg) 100%);
      border-top: 1px solid var(--border);
      padding: 100px 2rem 2rem;
      margin-top: 120px;
    }
    
    .footer-content {
      max-width: 1400px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 4rem;
    }
    
    .footer-section h4 {
      font-family: 'Cormorant SC', serif;
      letter-spacing: 0.1em;
      margin-bottom: 1.5rem;
      color: var(--primary);
      font-size: 1.1rem;
    }
    
    .footer-section ul {
      list-style: none;
    }
    
    .footer-section a {
      color: var(--text-muted);
      text-decoration: none;
      display: block;
      padding: 0.5rem 0;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      position: relative;
      padding-left: 0;
    }
    
    .footer-section a::before {
      content: '';
      position: absolute;
      left: 0;
      width: 0;
      height: 1px;
      background: var(--primary);
      bottom: 0.5rem;
      transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .footer-section a:hover {
      color: var(--primary);
      transform: translateX(4px);
    }
    
    .footer-section a:hover::before {
      width: 20px;
    }
    
    .footer-bottom {
      text-align: center;
      margin-top: 4rem;
      padding-top: 2.5rem;
      border-top: 1px solid var(--border);
      color: var(--text-muted);
      font-size: 0.9rem;
      letter-spacing: 0.03em;
    }
  </style>
</head>
<body>
  <!-- NAVIGATION -->
  <nav id="main-nav">
    <div class="nav-container">
      <a href="/" class="logo">EviWsMed</a>
      <button class="mobile-toggle" aria-label="Menü" id="mobile-toggle">☰</button>
      <ul class="nav-links" id="nav-links">
        <li><a href="/erkrankungen/">Erkrankungen</a></li>
        <li><a href="/glossar/">Glossar</a></li>
        <li><a href="/faq/">FAQ</a></li>
        <li><a href="/videos/">Videos</a></li>
      </ul>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-content">
      <span class="hero-badge">EVIDENZBASIERT</span>
      <h1>
        Evidenzbasierte<br>
        <em>Wirbelsäulenmedizin</em>
      </h1>
      <p class="hero-subtitle">
        Verständlich. Quellenbasiert. Für Patienten und Fachpersonal.
      </p>
      <a href="/erkrankungen/" class="hero-cta">Erkrankungen entdecken</a>
    </div>
  </section>

  <!-- NUMBERED STEPS -->
  <section class="steps">
    <h2>So nutzen Sie dieses <em>Portal</em></h2>
    <div class="steps-grid">
      <div class="step">
        <div class="step-number">01</div>
        <h3>Erkrankung finden</h3>
        <p>Wählen Sie aus über 30 Erkrankungen der Wirbelsäule</p>
      </div>
      <div class="step">
        <div class="step-number">02</div>
        <h3>Verständlich erklärt</h3>
        <p>Laien-Text mit aufklappbaren Fachinfo-Sektionen</p>
      </div>
      <div class="step">
        <div class="step-number">03</div>
        <h3>Quellenbasiert informiert</h3>
        <p>Alle Aussagen mit Cochrane, AWMF oder Peer-reviewed Studien belegt</p>
      </div>
    </div>
  </section>

  <!-- SCROLLING TICKER -->
  <section class="ticker-section">
    <h2>Erkrankungen, die wir abdecken</h2>
    <div class="ticker-wrapper">
      <div class="ticker">
        <span class="ticker-item">Bandscheibenvorfall</span>
        <span class="ticker-item">Spinalkanalstenose</span>
        <span class="ticker-item">Ischialgien</span>
        <span class="ticker-item">Rückenschmerzen</span>
        <span class="ticker-item">Wirbelgleiten (Spondylolisthesis)</span>
        <span class="ticker-item">Bandscheibendegeneration</span>
        <span class="ticker-item">Facettensyndrom</span>
        <span class="ticker-item">Skoliose</span>
        <!-- Duplicate for seamless loop -->
        <span class="ticker-item">Bandscheibenvorfall</span>
        <span class="ticker-item">Spinalkanalstenose</span>
        <span class="ticker-item">Ischialgien</span>
        <span class="ticker-item">Rückenschmerzen</span>
        <span class="ticker-item">Wirbelgleiten (Spondylolisthesis)</span>
        <span class="ticker-item">Bandscheibendegeneration</span>
        <span class="ticker-item">Facettensyndrom</span>
        <span class="ticker-item">Skoliose</span>
      </div>
    </div>
  </section>

  <!-- CATEGORY CARDS -->
  <section class="categories">
    <h2>Erkrankungskategorien</h2>
    <div class="category-grid">
      <a href="/erkrankungen/degenerativ/" class="category-card">
        <img src="/icons/kategorie-degenerativ.svg" alt="" class="category-icon" aria-hidden="true">
        <h3>Degenerativ</h3>
        <p>Verschleißbedingte Erkrankungen der Wirbelsäule</p>
        <ul>
          <li>Bandscheibenvorfall</li>
          <li>Spinalkanalstenose</li>
          <li>Facettensyndrom</li>
          <li>Rückenschmerzen</li>
        </ul>
      </a>
      
      <a href="/erkrankungen/verletzungen/" class="category-card">
        <img src="/icons/kategorie-verletzungen.svg" alt="" class="category-icon" aria-hidden="true">
        <h3>Verletzungen</h3>
        <p>Traumatische Schädigungen der Wirbelsäule</p>
        <ul>
          <li>Wirbelbrüche</li>
          <li>Schleudertrauma</li>
          <li>Bandscheibenverletzungen</li>
        </ul>
      </a>
      
      <a href="/erkrankungen/tumoren/" class="category-card">
        <img src="/icons/kategorie-tumoren.svg" alt="" class="category-icon" aria-hidden="true">
        <h3>Tumoren</h3>
        <p>Gut- und bösartige Neubildungen</p>
        <ul>
          <li>Spinale Tumoren</li>
          <li>Metastasen</li>
          <li>Hämangiome</li>
        </ul>
      </a>
      
      <a href="/erkrankungen/entzuendlich/" class="category-card">
        <img src="/icons/kategorie-entzuendlich.svg" alt="" class="category-icon" aria-hidden="true">
        <h3>Entzündungen</h3>
        <p>Infektiöse und autoimmune Prozesse</p>
        <ul>
          <li>Spondylodiszitis</li>
          <li>Morbus Bechterew</li>
          <li>Epiduraler Abszess</li>
        </ul>
      </a>
      
      <a href="/erkrankungen/fehlbildungen/" class="category-card">
        <img src="/icons/kategorie-fehlbildungen.svg" alt="" class="category-icon" aria-hidden="true">
        <h3>Fehlbildungen</h3>
        <p>Angeborene strukturelle Anomalien</p>
        <ul>
          <li>Skoliose</li>
          <li>Kyphose</li>
          <li>Spina bifida</li>
        </ul>
      </a>
    </div>
  </section>

  <!-- TRUST SECTION -->
  <section class="trust">
    <div class="trust-content">
      <h2>Auf Leitlinien <em>basiert</em></h2>
      <blockquote>
        „Bei lumbalen Radikulopathien sollte eine initiale konservative Therapie für mindestens 6 Wochen erfolgen, bevor operative Maßnahmen in Erwägung gezogen werden."
        <cite>— AWMF Leitlinie Lumbale Radikulopathie (2018)</cite>
      </blockquote>
      <blockquote>
        „Die Kernspintomographie (MRT) ist der Goldstandard zur Diagnostik von Bandscheibenvorfällen."
        <cite>— Deutsche Gesellschaft für Neurochirurgie</cite>
      </blockquote>
    </div>
  </section>

  <!-- AUTHOR SECTION -->
  <section class="author">
    <div class="author-image">👨⚕️</div>
    <div class="author-text">
      <h2>Über den Autor</h2>
      <p class="author-title">Dr. med. Jan-Philip Zeden</p>
      <p>
        Facharzt für Neurochirurgie mit Schwerpunkt Wirbelsäulenchirurgie. 
        Alle Artikel basieren auf aktuellen Leitlinien der AWMF, Cochrane Reviews 
        und peer-reviewed Studien aus PubMed.
      </p>
    </div>
  </section>

  <!-- COMPARISON TABLE -->
  <section class="comparison">
    <h2>Warum <em>evidenzbasiert?</em></h2>
    <div class="comparison-table">
      <div class="comparison-row">
        <div class="comparison-header"></div>
        <div class="comparison-header">EviWsMed</div>
        <div class="comparison-header">Dr. Google</div>
      </div>
      
      <div class="comparison-row">
        <div class="comparison-cell">AWMF-Leitlinien zitiert</div>
        <div class="comparison-cell check">✓</div>
        <div class="comparison-cell cross">✗</div>
      </div>
      
      <div class="comparison-row">
        <div class="comparison-cell">Peer-reviewed Quellen</div>
        <div class="comparison-cell check">✓</div>
        <div class="comparison-cell cross">✗</div>
      </div>
      
      <div class="comparison-row">
        <div class="comparison-cell">Fachärztlich geprüft</div>
        <div class="comparison-cell check">✓</div>
        <div class="comparison-cell cross">✗</div>
      </div>
      
      <div class="comparison-row">
        <div class="comparison-cell">Verständlich für Patienten</div>
        <div class="comparison-cell check">✓</div>
        <div class="comparison-cell cross">✗</div>
      </div>
      
      <div class="comparison-row">
        <div class="comparison-cell">Keine Werbung</div>
        <div class="comparison-cell check">✓</div>
        <div class="comparison-cell cross">✗</div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="footer-content">
      <div class="footer-section">
        <h4>Inhalte</h4>
        <ul>
          <li><a href="/erkrankungen/">Erkrankungen</a></li>
          <li><a href="/glossar/">Glossar</a></li>
          <li><a href="/faq/">Häufige Fragen</a></li>
          <li><a href="/videos/">Videos</a></li>
        </ul>
      </div>
      
      <div class="footer-section">
        <h4>Kategorien</h4>
        <ul>
          <li><a href="/erkrankungen/degenerativ/">Degenerativ</a></li>
          <li><a href="/erkrankungen/verletzungen/">Verletzungen</a></li>
          <li><a href="/erkrankungen/tumoren/">Tumoren</a></li>
          <li><a href="/erkrankungen/entzuendlich/">Entzündungen</a></li>
          <li><a href="/erkrankungen/fehlbildungen/">Fehlbildungen</a></li>
        </ul>
      </div>
      
      <div class="footer-section">
        <h4>Rechtliches</h4>
        <ul>
          <li><a href="/impressum/">Impressum</a></li>
          <li><a href="/datenschutz/">Datenschutz</a></li>
          <li><a href="/hinweis-medizinische-information/">Haftungsausschluss</a></li>
        </ul>
      </div>
    </div>
    
    <div class="footer-bottom">
      <p>&copy; 2026 EviWsMed — Evidenzbasierte Wirbelsäulenmedizin</p>
    </div>
  </footer>

  <script>
    // Mobile Menu Toggle
    const mobileToggle = document.getElementById('mobile-toggle');
    const navLinks = document.getElementById('nav-links');
    
    mobileToggle.addEventListener('click', () => {
      navLinks.classList.toggle('active');
      mobileToggle.textContent = navLinks.classList.contains('active') ? '✕' : '☰';
    });
    
    // Close menu on link click
    navLinks.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        navLinks.classList.remove('active');
        mobileToggle.textContent = '☰';
      });
    });
    
    // Sticky Nav Background on Scroll
    const nav = document.getElementById('main-nav');
    let lastScroll = 0;
    
    window.addEventListener('scroll', () => {
      const currentScroll = window.pageYOffset;
      
      if (currentScroll > 100) {
        nav.classList.add('scrolled');
      } else {
        nav.classList.remove('scrolled');
      }
      
      lastScroll = currentScroll;
    });
    
    // Intersection Observer für Scroll-Animationen
    const observerOptions = {
      threshold: 0.15,
      rootMargin: '0px 0px -80px 0px'
    };
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry, index) => {
        if (entry.isIntersecting) {
          // Staggered reveal
          setTimeout(() => {
            entry.target.classList.add('visible');
          }, index * 100);
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);
    
    // Observe animated elements
    document.querySelectorAll('.step, .category-card, .trust blockquote, .comparison-table, .author-image, .author-text').forEach(el => {
      observer.observe(el);
    });
    
    // Smooth Anchor Scrolling
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href'));
        if (target) {
          target.scrollIntoView({
            behavior: 'smooth',
            block: 'start'
          });
        }
      });
    });

    // Progressive enhancement: make above-fold content visible immediately
    document.addEventListener("DOMContentLoaded", function() {
      document.querySelectorAll(".step, .category-card, .trust-content, .author, .comparison, .hero-badge, .hero h1, .hero-subtitle, .hero .cta-button, .footer-section, h2").forEach(function(el) {
        var rect = el.getBoundingClientRect();
        if (rect.top < window.innerHeight * 1.2) {
          el.style.opacity = "1";
          el.style.transform = "none";
        }
      });
    });
  </script>
</body>
</html>
