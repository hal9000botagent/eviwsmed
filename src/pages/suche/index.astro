<h1 class="text-5xl md:text-7xl font-headline italic text-on-surface leading-tight max-w-4xl">
                Suchergebnisse für 'Bandscheibenvorfall LWS'
            </h1>
</header>
<!-- Sticky Filter Bar -->
<div class="sticky top-[84px] z-40 mb-16">
<div class="glass-card rounded-full px-4 py-2 flex items-center gap-2 overflow-x-auto no-scrollbar shadow-[0_20px_50px_rgba(44,44,44,0.04)]">
<button class="px-6 py-2 rounded-full bg-primary-container text-white text-xs font-label uppercase tracking-widest transition-all">Alle</button>
<button class="px-6 py-2 rounded-full text-stone-600 hover:bg-stone-200/50 text-xs font-label uppercase tracking-widest transition-all">Patienten</button>
