---
// EviWsMed V2 — Datenschutz
import '../styles/global.css';
---

<!DOCTYPE html>
<html class="light" lang="de">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Evidenzbasierte Wirbelsäulenmedizin</title>

<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&amp;family=Inter:wght@300;400;500;600;700&amp;family=Newsreader:opsz,wght@6..72,400;6..72,700&amp;family=DM+Mono&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>

<style>
        body {
            background-color: #F5F0E8; /* Ivory Base */
            font-family: 'Inter', sans-serif;
            scroll-behavior: smooth;
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
        }
        .glass-card {
            backdrop-filter: blur(28px);
            -webkit-backdrop-filter: blur(28px);
            background: rgba(255, 255, 255, 0.45);
            border: 1px solid rgba(255, 255, 255, 0.6);
            box-shadow: 
                inset 0 0 0 1px rgba(255, 255, 255, 0.4),
                0 4px 24px -1px rgba(0, 0, 0, 0.05);
            transition: all 400ms cubic-bezier(0.4, 0, 0.2, 1);
        }
        .glass-card:hover {
            background: rgba(255, 255, 255, 0.55);
            transform: translateY(-4px);
            box-shadow: 
                inset 0 0 0 1px rgba(255, 255, 255, 0.6),
                0 20px 40px -10px rgba(107, 29, 42, 0.12);
        }
        .editorial-shadow {
            box-shadow: 0 20px 40px -10px rgba(0,0,0,0.04);
        }
        .radial-glow {
            background: radial-gradient(circle at center, rgba(107, 29, 42, 0.05) 0%, rgba(168, 136, 74, 0.03) 50%, transparent 100%);
        }
        .no-scrollbar::-webkit-scrollbar { display: none; }
    </style>
</head>
<body class="bg-surface text-on-surface font-body antialiased">
<style>
        body {
            background-color: #F5F0E8; /* Ivory Base */
            font-family: 'Inter', sans-serif;
            scroll-behavior: smooth;
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
        }
        .glass-card {
            backdrop-filter: blur(28px);
            -webkit-backdrop-filter: blur(28px);
            background: rgba(255, 255, 255, 0.45);
            border: 1px solid rgba(255, 255, 255, 0.6);
            box-shadow: 
                inset 0 0 0 1px rgba(255, 255, 255, 0.4),
                0 4px 24px -1px rgba(0, 0, 0, 0.05);
            transition: all 400ms cubic-bezier(0.4, 0, 0.2, 1);
        }
        .glass-card:hover {
            background: rgba(255, 255, 255, 0.55);
            transform: translateY(-4px);
            box-shadow: 
                inset 0 0 0 1px rgba(255, 255, 255, 0.6),
                0 20px 40px -10px rgba(107, 29, 42, 0.12);
        }
        .editorial-shadow {
            box-shadow: 0 20px 40px -10px rgba(0,0,0,0.04);
        }
        .radial-glow {
            background: radial-gradient(circle at center, rgba(107, 29, 42, 0.05) 0%, rgba(168, 136, 74, 0.03) 50%, transparent 100%);
        }
        .no-scrollbar::-webkit-scrollbar { display: none; }
    </style>
<div class="min-h-screen flex flex-col">
  <!-- Minimal Nav -->
  <nav class="fixed top-0 w-full z-50 glass-panel">
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
      <a href="/" class="font-headline text-xl text-primary-container italic">Evidenzbasierte Wirbelsäulenmedizin</a>
      <div class="flex gap-8 items-center">
        <a href="/erkrankungen" class="font-label text-xs tracking-widest uppercase text-on-surface-variant hover:text-primary-container transition-all duration-300">Erkrankungen</a>
        <a href="/glossar" class="font-label text-xs tracking-widest uppercase text-on-surface-variant hover:text-primary-container transition-all duration-300">Glossar</a>
        <a href="/quiz" class="font-label text-xs tracking-widest uppercase text-on-surface-variant hover:text-primary-container transition-all duration-300">Selbsttest</a>
        <a href="/ueber-uns" class="font-label text-xs tracking-widest uppercase text-on-surface-variant hover:text-primary-container transition-all duration-300">Über uns</a>
      </div>
    </div>
  <button id="dark-mode-toggle" class="p-2 rounded-full hover:bg-surface-container transition-colors ml-4" aria-label="Dark Mode"><span class="material-symbols-outlined">dark_mode</span></button></nav>

  <!-- Content -->
  <main class="flex-1 pt-24 pb-16">
    <div class="max-w-3xl mx-auto px-6">
      <h1 class="font-headline text-4xl text-primary-container mb-8">Datenschutz</h1>
      <div class="bg-secondary-container/20 border border-secondary/20 rounded-xl p-8 text-center">
        <span class="material-symbols-outlined text-4xl text-secondary mb-4 block">construction</span>
        <p class="font-body text-lg text-on-surface-variant">Diese Seite wird aktuell überarbeitet.</p>
        <p class="font-body text-sm text-outline mt-2">Inhalte folgen in Kürze.</p>
      </div>
      
    </div>
  </main>

  <!-- Footer -->
  <footer class="border-t border-outline-variant/15 py-8">
    <div class="max-w-7xl mx-auto px-6 flex justify-between items-center text-xs text-outline">
      <span>© 2026 Evidenzbasierte Wirbelsäulenmedizin</span>
      <div class="flex gap-6">
        <a href="/impressum" class="hover:text-primary-container transition-colors">Impressum</a>
        <a href="/datenschutz" class="hover:text-primary-container transition-colors">Datenschutz</a>
      </div>
    </div>
  </footer>
</div>
<script is:inline>
const toggle=document.getElementById("dark-mode-toggle");
const html=document.documentElement;
const icon=toggle?.querySelector(".material-symbols-outlined");
const savedMode=localStorage.getItem("theme")||"light";
html.classList.remove("light","dark");
html.classList.add(savedMode);
if(icon)icon.textContent=savedMode==="dark"?"light_mode":"dark_mode";
toggle?.addEventListener("click",()=>{
const current=html.classList.contains("dark")?"dark":"light";
const next=current==="dark"?"light":"dark";
html.classList.remove(current);
html.classList.add(next);
localStorage.setItem("theme",next);
if(icon)icon.textContent=next==="dark"?"light_mode":"dark_mode";
});
</script>
</body>
</html>