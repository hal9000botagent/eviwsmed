---
// EviWsMed Landing Page — Function Health Stil adaptiert
// Custom Astro Page OHNE Starlight Layout
const title = 'Evidenzbasierte Wirbelsäulenmedizin';
const description = 'Verständlich. Quellenbasiert. Für Patienten und Fachpersonal.';
const siteUrl = 'https://evidenzbasierte-wirbelsaeulenmedizin.de';
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="icon" type="image/png" href="/favicon.png">
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Cormorant+SC:wght@300;400;500;600&display=swap" rel="stylesheet">
  
  <!-- Schema.org -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "MedicalWebPage",
      "name": "Evidenzbasierte Wirbelsäulenmedizin",
      "url": "https://evidenzbasierte-wirbelsaeulenmedizin.de",
      "description": "Evidenzbasierte Fachartikel und Patienteninformationen zur Wirbelsäulenmedizin",
      "inLanguage": "de",
      "medicalAudience": {
        "@type": "MedicalAudience",
        "audienceType": "Patient"
      },
      "publisher": {
        "@type": "Organization",
        "name": "EviWsMed"
      }
    }
  </script>
  
  <style>
    /* ─── RESET & BASE ─── */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    :root {
      /* Light Mode */
      --bg: #F5F0E8;
      --text: #2C2C2C;
      --text-muted: #6B6155;
      --primary: #6B1D2A;
      --primary-hover: #4a1019;
      --accent: #2D4A3E;
      --gold: #A8884A;
      --border: #D4CBBA;
      --card-bg: #FFFDF7;
      --nav-bg: rgba(245, 240, 232, 0.95);
    }
    
    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #1A1A1F;
        --text: #E2DCD2;
        --text-muted: #9C9487;
        --primary: #C4586A;
        --primary-hover: #f3d0d6;
        --accent: #5A9E82;
        --gold: #C4A96A;
        --border: #3A3A42;
        --card-bg: #242429;
        --nav-bg: rgba(26, 26, 31, 0.95);
      }
    }
    
    body {
      font-family: 'EB Garamond', Georgia, serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.7;
      font-size: 18px;
    }
    
    h1, h2, h3 {
      font-family: 'Playfair Display', Georgia, serif;
      font-weight: 700;
      line-height: 1.2;
    }
    
    h1 {
      font-size: clamp(2.5rem, 5vw, 4rem);
    }
    
    h2 {
      font-size: clamp(1.8rem, 4vw, 2.5rem);
      margin-bottom: 1rem;
    }
    
    h3 {
      font-size: clamp(1.3rem, 3vw, 1.8rem);
      font-weight: 400;
      font-style: italic;
    }
    
    /* ─── NAVIGATION ─── */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--nav-bg);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
      padding: 1rem 0;
    }
    
    .nav-container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    
    .logo {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--primary);
      text-decoration: none;
    }
    
    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
      font-family: 'Cormorant SC', serif;
      letter-spacing: 0.08em;
    }
    
    .nav-links a {
      color: var(--text);
      text-decoration: none;
      font-weight: 500;
      transition: color 0.2s;
    }
    
    .nav-links a:hover {
      color: var(--primary);
    }
    
    .mobile-toggle {
      display: none;
      background: none;
      border: none;
      color: var(--text);
      font-size: 1.5rem;
      cursor: pointer;
    }
    
    @media (max-width: 768px) {
      .nav-links {
        position: fixed;
        top: 60px;
        left: 0;
        right: 0;
        background: var(--nav-bg);
        flex-direction: column;
        padding: 2rem;
        gap: 1rem;
        transform: translateY(-150%);
        transition: transform 0.3s ease;
        border-bottom: 1px solid var(--border);
      }
      
      .nav-links.active {
        transform: translateY(0);
      }
      
      .mobile-toggle {
        display: block;
      }
    }
    
    /* ─── HERO ─── */
    .hero {
      min-height: 90vh;
      display: flex;
      align-items: center;
      background: linear-gradient(135deg, var(--bg) 0%, var(--card-bg) 100%);
      position: relative;
      overflow: hidden;
    }
    
    .hero::before {
      content: '';
      position: absolute;
      top: 0;
      right: 0;
      width: 50%;
      height: 100%;
      background: 
        linear-gradient(45deg, transparent 30%, var(--accent) 30%, var(--accent) 31%, transparent 31%),
        linear-gradient(-45deg, transparent 30%, var(--gold) 30%, var(--gold) 31%, transparent 31%);
      opacity: 0.03;
      pointer-events: none;
    }
    
    .hero-content {
      max-width: 1400px;
      margin: 0 auto;
      padding: 4rem 2rem;
      position: relative;
      z-index: 1;
    }
    
    .hero-badge {
      display: inline-block;
      font-family: 'Cormorant SC', serif;
      font-size: 0.9rem;
      letter-spacing: 0.15em;
      color: var(--gold);
      background: rgba(168, 136, 74, 0.1);
      padding: 0.5rem 1.2rem;
      border-radius: 20px;
      margin-bottom: 2rem;
      border: 1px solid var(--gold);
    }
    
    .hero h1 {
      margin-bottom: 1rem;
      color: var(--primary);
    }
    
    .hero h1 em {
      font-style: italic;
      display: block;
    }
    
    .hero-subtitle {
      font-size: 1.3rem;
      color: var(--text-muted);
      margin-bottom: 2rem;
      max-width: 700px;
    }
    
    .hero-cta {
      display: inline-block;
      background: var(--primary);
      color: #FFFDF7;
      padding: 1rem 2.5rem;
      border-radius: 6px;
      text-decoration: none;
      font-family: 'Cormorant SC', serif;
      letter-spacing: 0.12em;
      font-size: 1.1rem;
      transition: all 0.3s;
      border: 2px solid var(--primary);
    }
    
    .hero-cta:hover {
      background: var(--primary-hover);
      border-color: var(--primary-hover);
      transform: translateY(-2px);
    }
    
    /* ─── NUMBERED STEPS ─── */
    .steps {
      max-width: 1200px;
      margin: 5rem auto;
      padding: 0 2rem;
    }
    
    .steps h2 {
      text-align: center;
      margin-bottom: 3rem;
    }
    
    .steps h2 em {
      color: var(--primary);
      font-style: italic;
    }
    
    .steps-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 3rem;
    }
    
    .step {
      text-align: center;
    }
    
    .step-number {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 3rem;
      font-weight: 700;
      color: var(--gold);
      opacity: 0.3;
      margin-bottom: 0.5rem;
    }
    
    .step h3 {
      margin-bottom: 0.75rem;
      color: var(--primary);
    }
    
    .step p {
      color: var(--text-muted);
      font-size: 1rem;
    }
    
    /* ─── SCROLLING TICKER ─── */
    .ticker-section {
      background: var(--card-bg);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: 3rem 0;
      overflow: hidden;
    }
    
    .ticker-section h2 {
      text-align: center;
      margin-bottom: 2rem;
    }
    
    .ticker-wrapper {
      overflow: hidden;
      position: relative;
      margin: 0 auto;
    }
    
    .ticker {
      display: flex;
      animation: scroll 40s linear infinite;
    }
    
    .ticker-item {
      flex-shrink: 0;
      padding: 0.75rem 2rem;
      margin: 0 1rem;
      background: var(--bg);
      border-radius: 25px;
      border: 1px solid var(--border);
      white-space: nowrap;
      font-family: 'Cormorant SC', serif;
      letter-spacing: 0.05em;
    }
    
    @keyframes scroll {
      0% {
        transform: translateX(0);
      }
      100% {
        transform: translateX(-50%);
      }
    }
    
    /* ─── CATEGORY CARDS ─── */
    .categories {
      max-width: 1400px;
      margin: 5rem auto;
      padding: 0 2rem;
    }
    
    .categories h2 {
      text-align: center;
      margin-bottom: 3rem;
    }
    
    .category-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 2rem;
    }
    
    .category-card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 2rem;
      transition: all 0.3s;
      text-decoration: none;
      color: var(--text);
    }
    
    .category-card:hover {
      transform: translateY(-4px);
      border-color: var(--primary);
      box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    }
    
    .category-card h3 {
      color: var(--primary);
      margin-bottom: 1rem;
    }
    
    .category-card ul {
      list-style: none;
      margin-top: 1rem;
    }
    
    .category-card li {
      color: var(--text-muted);
      padding: 0.4rem 0;
      font-size: 0.95rem;
    }
    
    .category-card li::before {
      content: '→';
      color: var(--gold);
      margin-right: 0.5rem;
    }
    
    /* ─── TRUST SECTION ─── */
    .trust {
      background: var(--card-bg);
      border-top: 1px solid var(--border);
      padding: 4rem 2rem;
      margin-top: 5rem;
    }
    
    .trust-content {
      max-width: 900px;
      margin: 0 auto;
      text-align: center;
    }
    
    .trust h2 {
      margin-bottom: 2rem;
    }
    
    .trust blockquote {
      font-size: 1.2rem;
      font-style: italic;
      color: var(--text-muted);
      border-left: 3px solid var(--gold);
      padding-left: 2rem;
      margin: 2rem 0;
      text-align: left;
    }
    
    .trust cite {
      display: block;
      margin-top: 1rem;
      font-size: 0.95rem;
      font-style: normal;
      color: var(--text);
      font-family: 'Cormorant SC', serif;
    }
    
    /* ─── AUTHOR SECTION ─── */
    .author {
      max-width: 1000px;
      margin: 5rem auto;
      padding: 0 2rem;
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 3rem;
      align-items: center;
    }
    
    @media (max-width: 768px) {
      .author {
        grid-template-columns: 1fr;
      }
    }
    
    .author-image {
      width: 100%;
      aspect-ratio: 1;
      background: linear-gradient(135deg, var(--accent) 0%, var(--primary) 100%);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 5rem;
      color: #FFFDF7;
    }
    
    .author h2 {
      margin-bottom: 0.5rem;
    }
    
    .author-title {
      color: var(--text-muted);
      font-size: 1rem;
      margin-bottom: 1.5rem;
      font-family: 'Cormorant SC', serif;
      letter-spacing: 0.08em;
    }
    
    /* ─── COMPARISON TABLE ─── */
    .comparison {
      max-width: 1200px;
      margin: 5rem auto;
      padding: 0 2rem;
    }
    
    .comparison h2 {
      text-align: center;
      margin-bottom: 3rem;
    }
    
    .comparison-table {
      background: var(--card-bg);
      border-radius: 8px;
      overflow: hidden;
      border: 1px solid var(--border);
    }
    
    .comparison-row {
      display: grid;
      grid-template-columns: 1.5fr 1fr 1fr;
      border-bottom: 1px solid var(--border);
    }
    
    .comparison-row:last-child {
      border-bottom: none;
    }
    
    .comparison-header {
      background: var(--primary);
      color: #FFFDF7;
      font-family: 'Cormorant SC', serif;
      letter-spacing: 0.1em;
      text-align: center;
      padding: 1rem;
      font-weight: 600;
    }
    
    .comparison-cell {
      padding: 1.2rem;
      border-right: 1px solid var(--border);
    }
    
    .comparison-cell:last-child {
      border-right: none;
    }
    
    .check {
      color: var(--accent);
      font-size: 1.5rem;
      text-align: center;
    }
    
    .cross {
      color: var(--primary);
      font-size: 1.5rem;
      text-align: center;
      opacity: 0.3;
    }
    
    @media (max-width: 768px) {
      .comparison-row {
        grid-template-columns: 2fr 1fr 1fr;
      }
      
      .comparison-cell {
        padding: 0.8rem;
        font-size: 0.9rem;
      }
    }
    
    /* ─── FOOTER ─── */
    footer {
      background: var(--card-bg);
      border-top: 1px solid var(--border);
      padding: 3rem 2rem 2rem;
      margin-top: 5rem;
    }
    
    .footer-content {
      max-width: 1400px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 3rem;
    }
    
    .footer-section h4 {
      font-family: 'Cormorant SC', serif;
      letter-spacing: 0.1em;
      margin-bottom: 1rem;
      color: var(--primary);
    }
    
    .footer-section ul {
      list-style: none;
    }
    
    .footer-section a {
      color: var(--text-muted);
      text-decoration: none;
      display: block;
      padding: 0.3rem 0;
      transition: color 0.2s;
    }
    
    .footer-section a:hover {
      color: var(--primary);
    }
    
    .footer-bottom {
      text-align: center;
      margin-top: 3rem;
      padding-top: 2rem;
      border-top: 1px solid var(--border);
      color: var(--text-muted);
      font-size: 0.9rem;
    }
  </style>
</head>
<body>
  <!-- NAVIGATION -->
  <nav>
    <div class="nav-container">
      <a href="/" class="logo">EviWsMed</a>
      <button class="mobile-toggle" aria-label="Menü" id="mobile-toggle">☰</button>
      <ul class="nav-links" id="nav-links">
        <li><a href="/erkrankungen/">Erkrankungen</a></li>
        <li><a href="/glossar/">Glossar</a></li>
        <li><a href="/faq/">FAQ</a></li>
        <li><a href="/videos/">Videos</a></li>
      </ul>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-content">
      <span class="hero-badge">EVIDENZBASIERT</span>
      <h1>
        Evidenzbasierte<br>
        <em>Wirbelsäulenmedizin</em>
      </h1>
      <p class="hero-subtitle">
        Verständlich. Quellenbasiert. Für Patienten und Fachpersonal.
      </p>
      <a href="/erkrankungen/" class="hero-cta">Erkrankungen entdecken</a>
    </div>
  </section>

  <!-- NUMBERED STEPS -->
  <section class="steps">
    <h2>So nutzen Sie dieses <em>Portal</em></h2>
    <div class="steps-grid">
      <div class="step">
        <div class="step-number">01</div>
        <h3>Erkrankung finden</h3>
        <p>Wählen Sie aus über 30 Erkrankungen der Wirbelsäule</p>
      </div>
      <div class="step">
        <div class="step-number">02</div>
        <h3>Verständlich erklärt</h3>
        <p>Laien-Text mit aufklappbaren Fachinfo-Sektionen</p>
      </div>
      <div class="step">
        <div class="step-number">03</div>
        <h3>Quellenbasiert informiert</h3>
        <p>Alle Aussagen mit Cochrane, AWMF oder Peer-reviewed Studien belegt</p>
      </div>
    </div>
  </section>

  <!-- SCROLLING TICKER -->
  <section class="ticker-section">
    <h2>Erkrankungen, die wir abdecken</h2>
    <div class="ticker-wrapper">
      <div class="ticker">
        <span class="ticker-item">Bandscheibenvorfall</span>
        <span class="ticker-item">Spinalkanalstenose</span>
        <span class="ticker-item">Ischialgien</span>
        <span class="ticker-item">Rückenschmerzen</span>
        <span class="ticker-item">Wirbelgleiten (Spondylolisthesis)</span>
        <span class="ticker-item">Bandscheibendegeneration</span>
        <span class="ticker-item">Facettensyndrom</span>
        <span class="ticker-item">Skoliose</span>
        <!-- Duplicate for seamless loop -->
        <span class="ticker-item">Bandscheibenvorfall</span>
        <span class="ticker-item">Spinalkanalstenose</span>
        <span class="ticker-item">Ischialgien</span>
        <span class="ticker-item">Rückenschmerzen</span>
        <span class="ticker-item">Wirbelgleiten (Spondylolisthesis)</span>
        <span class="ticker-item">Bandscheibendegeneration</span>
        <span class="ticker-item">Facettensyndrom</span>
        <span class="ticker-item">Skoliose</span>
      </div>
    </div>
  </section>

  <!-- CATEGORY CARDS -->
  <section class="categories">
    <h2>Erkrankungskategorien</h2>
    <div class="category-grid">
      <a href="/erkrankungen/degenerativ/" class="category-card">
        <h3>Degenerativ</h3>
        <p>Verschleißbedingte Erkrankungen der Wirbelsäule</p>
        <ul>
          <li>Bandscheibenvorfall</li>
          <li>Spinalkanalstenose</li>
          <li>Facettensyndrom</li>
          <li>Rückenschmerzen</li>
        </ul>
      </a>
      
      <a href="/erkrankungen/verletzungen/" class="category-card">
        <h3>Verletzungen</h3>
        <p>Traumatische Schädigungen der Wirbelsäule</p>
        <ul>
          <li>Wirbelbrüche</li>
          <li>Schleudertrauma</li>
          <li>Bandscheibenverletzungen</li>
        </ul>
      </a>
      
      <a href="/erkrankungen/tumoren/" class="category-card">
        <h3>Tumoren</h3>
        <p>Gut- und bösartige Neubildungen</p>
        <ul>
          <li>Spinale Tumoren</li>
          <li>Metastasen</li>
          <li>Hämangiome</li>
        </ul>
      </a>
      
      <a href="/erkrankungen/entzuendlich/" class="category-card">
        <h3>Entzündungen</h3>
        <p>Infektiöse und autoimmune Prozesse</p>
        <ul>
          <li>Spondylodiszitis</li>
          <li>Morbus Bechterew</li>
          <li>Epiduraler Abszess</li>
        </ul>
      </a>
      
      <a href="/erkrankungen/fehlbildungen/" class="category-card">
        <h3>Fehlbildungen</h3>
        <p>Angeborene strukturelle Anomalien</p>
        <ul>
          <li>Skoliose</li>
          <li>Kyphose</li>
          <li>Spina bifida</li>
        </ul>
      </a>
    </div>
  </section>

  <!-- TRUST SECTION -->
  <section class="trust">
    <div class="trust-content">
      <h2>Auf Leitlinien <em>basiert</em></h2>
      <blockquote>
        „Bei lumbalen Radikulopathien sollte eine initiale konservative Therapie für mindestens 6 Wochen erfolgen, bevor operative Maßnahmen in Erwägung gezogen werden."
        <cite>— AWMF Leitlinie Lumbale Radikulopathie (2018)</cite>
      </blockquote>
      <blockquote>
        „Die Kernspintomographie (MRT) ist der Goldstandard zur Diagnostik von Bandscheibenvorfällen."
        <cite>— Deutsche Gesellschaft für Neurochirurgie</cite>
      </blockquote>
    </div>
  </section>

  <!-- AUTHOR SECTION -->
  <section class="author">
    <div class="author-image">👨‍⚕️</div>
    <div class="author-text">
      <h2>Über den Autor</h2>
      <p class="author-title">Dr. med. Jan-Philip Zeden</p>
      <p>
        Facharzt für Neurochirurgie mit Schwerpunkt Wirbelsäulenchirurgie. 
        Alle Artikel basieren auf aktuellen Leitlinien der AWMF, Cochrane Reviews 
        und peer-reviewed Studien aus PubMed.
      </p>
    </div>
  </section>

  <!-- COMPARISON TABLE -->
  <section class="comparison">
    <h2>Warum <em>evidenzbasiert?</em></h2>
    <div class="comparison-table">
      <div class="comparison-row">
        <div class="comparison-header"></div>
        <div class="comparison-header">EviWsMed</div>
        <div class="comparison-header">Dr. Google</div>
      </div>
      
      <div class="comparison-row">
        <div class="comparison-cell">AWMF-Leitlinien zitiert</div>
        <div class="comparison-cell check">✓</div>
        <div class="comparison-cell cross">✗</div>
      </div>
      
      <div class="comparison-row">
        <div class="comparison-cell">Peer-reviewed Quellen</div>
        <div class="comparison-cell check">✓</div>
        <div class="comparison-cell cross">✗</div>
      </div>
      
      <div class="comparison-row">
        <div class="comparison-cell">Fachärztlich geprüft</div>
        <div class="comparison-cell check">✓</div>
        <div class="comparison-cell cross">✗</div>
      </div>
      
      <div class="comparison-row">
        <div class="comparison-cell">Verständlich für Patienten</div>
        <div class="comparison-cell check">✓</div>
        <div class="comparison-cell cross">✗</div>
      </div>
      
      <div class="comparison-row">
        <div class="comparison-cell">Keine Werbung</div>
        <div class="comparison-cell check">✓</div>
        <div class="comparison-cell cross">✗</div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="footer-content">
      <div class="footer-section">
        <h4>Inhalte</h4>
