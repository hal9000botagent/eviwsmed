---
// EviWsMed V2 — Landing Page (Stitch Design)
import '../styles/global.css';
---

<!DOCTYPE html>

<html class="light" lang="de"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Evidenzbasierte Wirbelsäulenmedizin</title>

<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&amp;family=Inter:wght@300;400;500;600;700&amp;family=Newsreader:opsz,wght@6..72,400;6..72,700&amp;family=DM+Mono&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>

<style>
        body {
            background-color: var(--md-background); /* Ivory Base */
            font-family: 'Inter', sans-serif;
            scroll-behavior: smooth;
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
        }
        .glass-card {
            backdrop-filter: blur(28px);
            -webkit-backdrop-filter: blur(28px);
            background: rgba(255, 255, 255, 0.45);
            border: 1px solid rgba(255, 255, 255, 0.6);
            box-shadow: 
                inset 0 0 0 1px rgba(255, 255, 255, 0.4),
                0 4px 24px -1px rgba(0, 0, 0, 0.05);
            transition: all 400ms cubic-bezier(0.4, 0, 0.2, 1);
        }
        .glass-card:hover {
            background: rgba(255, 255, 255, 0.55);
            transform: translateY(-4px);
            box-shadow: 
                inset 0 0 0 1px rgba(255, 255, 255, 0.6),
                0 20px 40px -10px rgba(107, 29, 42, 0.12);
        }
        .editorial-shadow {
            box-shadow: 0 20px 40px -10px rgba(0,0,0,0.04);
        }
        .radial-glow {
            background: radial-gradient(circle at center, rgba(107, 29, 42, 0.05) 0%, rgba(168, 136, 74, 0.03) 50%, transparent 100%);
        }
        .no-scrollbar::-webkit-scrollbar { display: none; }
    </style>
</head>
<body class="text-on-surface selection:bg-primary-fixed selection:text-primary">
<!-- TopAppBar -->
<nav class="fixed top-0 w-full z-50 bg-white/45 backdrop-blur-[24px] border-b border-white/30 flex justify-between items-center w-full px-8 py-4 max-w-none transition-all duration-400 ease-in-out">
<div class="flex items-center gap-2">
