<div class="font-sans Inter text-sm tracking-wide text-[#2C2C2C]/60 dark:text-[#E2DCD2]/60">
                © 2024 The Clinical Curator. All Rights Reserved.
            </div>
</div>
</footer>
<script is:inline>
const toggle=document.getElementById("dark-mode-toggle");
const html=document.documentElement;
const icon=toggle?.querySelector(".material-symbols-outlined");
const savedMode=localStorage.getItem("theme")||"light";
html.classList.remove("light","dark");
html.classList.add(savedMode);
if(icon)icon.textContent=savedMode==="dark"?"light_mode":"dark_mode";
toggle?.addEventListener("click",()=>{
const current=html.classList.contains("dark")?"dark":"light";
const next=current==="dark"?"light":"dark";
html.classList.remove(current);
html.classList.add(next);
localStorage.setItem("theme",next);
if(icon)icon.textContent=next==="dark"?"light_mode":"dark_mode";
});
</script>
</body></html>