---
// EviWsMed V2 — termin (Stitch Design)
import '../../styles/global.css';
---

<!DOCTYPE html>

<html class="light" lang="de"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>

<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&amp;family=Inter:wght@300;400;500;600;700&amp;family=DM+Mono&amp;family=Newsreader:ital,wght@0,400;0,700;1,400&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>

<style>
      .glass-card {
        background: rgba(255, 255, 255, 0.4);
        backdrop-filter: blur(30px);
        -webkit-backdrop-filter: blur(30px);
      }
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
      }
    </style>
</head>
<body class="bg-surface font-body text-on-surface antialiased min-h-screen">
<!-- TopAppBar -->
<header class="fixed top-0 w-full z-50 bg-[#F5F0E8]/60 dark:bg-[#1A1A1F]/60 backdrop-blur-[20px] shadow-[0_20px_50px_rgba(44,44,44,0.05)]">
<div class="flex justify-between items-center px-8 py-6 max-w-full mx-auto">
<div class="text-2xl font-headline italic text-[#6B1D2A] dark:text-[#A8884A]">
                The Clinical Curator
            </div>
<nav class="hidden md:flex items-center space-gap-8 gap-x-8">
<a class="text-[#2C2C2C]/70 dark:text-[#E2DCD2]/70 hover:text-[#6B1D2A] transition-all duration-400 ease-[cubic-bezier(0.4,0,0.2,1)]" href="#">Consultations</a>
<a class="text-[#6B1D2A] dark:text-[#A8884A] font-bold border-b border-[#6B1D2A]/20 transition-all duration-400 ease-[cubic-bezier(0.4,0,0.2,1)]" href="#">Specialists</a>
<a class="text-[#2C2C2C]/70 dark:text-[#E2DCD2]/70 hover:text-[#6B1D2A] transition-all duration-400 ease-[cubic-bezier(0.4,0,0.2,1)]" href="#">Wellness</a>
<a class="text-[#2C2C2C]/70 dark:text-[#E2DCD2]/70 hover:text-[#6B1D2A] transition-all duration-400 ease-[cubic-bezier(0.4,0,0.2,1)]" href="#">Archives</a>
</nav>
<div class="flex items-center gap-6">
<span class="material-symbols-outlined text-[#6B1D2A] cursor-pointer" data-icon="account_circle">account_circle</span>
<button class="bg-primary-container text-white px-6 py-2 rounded-full text-xs font-label uppercase tracking-widest hover:scale-[0.98] transition-transform duration-400">
                    Book Appointment
                </button>
</div>
</div>
</header>
<main class="pt-32 pb-24 px-8 max-w-7xl mx-auto">
<!-- Step Progress Indicator -->
<nav class="mb-16 flex items-center justify-start gap-12">
<div class="flex items-center gap-3">
<span class="font-mono text-xs text-primary bg-primary/10 w-8 h-8 rounded-full flex items-center justify-center">01</span>
<span class="text-xs font-label uppercase tracking-[0.2em] font-semibold text-primary">Specialist</span>
</div>
<div class="h-[1px] w-12 bg-outline-variant/30"></div>
<div class="flex items-center gap-3 opacity-40">
<span class="font-mono text-xs w-8 h-8 rounded-full flex items-center justify-center border border-outline-variant">02</span>
<span class="text-xs font-label uppercase tracking-[0.2em]">Schedule</span>
</div>
<div class="h-[1px] w-12 bg-outline-variant/30"></div>
<div class="flex items-center gap-3 opacity-40">
<span class="font-mono text-xs w-8 h-8 rounded-full flex items-center justify-center border border-outline-variant">03</span>
<span class="text-xs font-label uppercase tracking-[0.2em]">Details</span>
</div>
</nav>
<!-- Page Title Section -->
<div class="grid grid-cols-1 md:grid-cols-12 gap-8 mb-20 items-end">
<div class="md:col-span-8">
<h1 class="font-headline text-6xl md:text-8xl text-primary leading-tight tracking-tight">Spezialist wählen</h1>
</div>
<div class="md:col-span-4 pb-4">
<p class="text-on-surface-variant font-body leading-relaxed text-lg border-l border-primary/20 pl-6">
                    Wählen Sie einen Experten aus unserem kuratierten Team für Ihre individuelle Beratung.
                </p>
</div>
</div>
<!-- Specialist Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
<!-- Specialist Card 1 -->
<div class="glass-card rounded-xl overflow-hidden group hover:shadow-[0_40px_80px_rgba(107,29,42,0.08)] transition-all duration-700">
<div class="aspect-[4/5] overflow-hidden">
<img class="w-full h-full object-cover grayscale-[0.3] group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700" data-alt="Portrait of a distinguished male medical specialist in clinic" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAitkWem-BZhevVWzizWBsE1tZXACLW8sq370MKlWxBF6VDw1ofxxpHRVGWi-e3FkZ51639ZrwOBwZLXlehUrM7x70moy9qI8KLyf_jaoyOAx_RG-s13g6SE9fmLkjwAKuZkQVw_Ryf-slE3-dHWFvymd5pEVpicxzIjZCWDQstu0aHSnNZbV5cIoE_h52oODN5isKeRVUtQveBvurmROtKTcSfXMPLgXWhbaZ52R5WzmFr6faxRIB3GKiOWwQwLas8bOPHZJIw-kw"/>
</div>
<div class="p-8">
<span class="font-mono text-[10px] uppercase tracking-widest text-secondary mb-2 block">Dermatology</span>
<h3 class="font-headline text-3xl mb-1 text-primary">Dr. Julian Thorne</h3>
<p class="text-sm font-body text-on-surface-variant mb-6">Spezialist für ästhetische Dermatologie</p>
<div class="flex items-center gap-2 mb-8 bg-surface-container/50 p-3 rounded-lg">
<span class="material-symbols-outlined text-sm text-tertiary" data-icon="event_available">event_available</span>
<span class="font-mono text-xs text-on-surface-variant">Available from Mon, 12 Oct</span>
</div>
<button class="w-full bg-primary-container text-white py-4 rounded-full font-label text-xs uppercase tracking-widest group-hover:bg-primary transition-colors">
                        Spezialist Auswählen
                    </button>
</div>
</div>
<!-- Specialist Card 2 -->
<div class="glass-card rounded-xl overflow-hidden group hover:shadow-[0_40px_80px_rgba(107,29,42,0.08)] transition-all duration-700">
<div class="aspect-[4/5] overflow-hidden">
<img class="w-full h-full object-cover grayscale-[0.3] group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700" data-alt="Professional female physician with soft lighting and neutral background" src="https://lh3.googleusercontent.com/aida-public/AB6AXuA4NNFG_W1obSphykJi_mhDC5nTU8KFaHWC9TJqBrbW10Oxp7kjE1hGfMrtL-cacbqioagm3sPOi6PlF5Hs8WCOqx25XNzPzwPGiiyo5oTWD37-gM3nv9pH_oU5E_pGtx5J-_bOyg4xSRkmogInuRUaCL1IeB61s-I57KppQ47YzfRPCZE99SVAnwAwHuLfTReayD2RR1ufhMtbCaqetQhz86FcEtkJca3H0tyPTSX-9yOrQS_-17J67t6qqBVk3daDfKjE3DwMHjQ"/>
</div>
<div class="p-8">
<span class="font-mono text-[10px] uppercase tracking-widest text-secondary mb-2 block">Cardiology</span>
<h3 class="font-headline text-3xl mb-1 text-primary">Dr. Elena Vance</h3>
<p class="text-sm font-body text-on-surface-variant mb-6">Expertin für präventive Herzgesundheit</p>
<div class="flex items-center gap-2 mb-8 bg-surface-container/50 p-3 rounded-lg">
<span class="material-symbols-outlined text-sm text-tertiary" data-icon="event_available">event_available</span>
<span class="font-mono text-xs text-on-surface-variant">Next opening today at 16:00</span>
</div>
<button class="w-full bg-primary-container text-white py-4 rounded-full font-label text-xs uppercase tracking-widest group-hover:bg-primary transition-colors">
                        Spezialist Auswählen
                    </button>
</div>
</div>
<!-- Specialist Card 3 -->
<div class="glass-card rounded-xl overflow-hidden group hover:shadow-[0_40px_80px_rgba(107,29,42,0.08)] transition-all duration-700">
<div class="aspect-[4/5] overflow-hidden">
<img class="w-full h-full object-cover grayscale-[0.3] group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700" data-alt="Kind elderly medical professor in modern studio setting" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAY3ViDAtfDvOSU6T01RlZjUWVFXxsV_FasDqkWnu5xbfT8k9006a1W-vQfwTQvUcFDHDrEf_UkZvVk0nYwfk0BqmIbVOAiuzWYQbAgmibIlOefB--WJh5rIwHYFFZi0EkXNEAwugGc0gD1WLT03ec8ntrneHtJz7bcTlWMT1Dt3kuebZuIyNtsC4KJVgZCS3hIVdxSZ4BKulV3QFxRp79dGRtMgqr4CGecoONmE8w5HAlJPVkxyzxHvQQdTdBZ2QOf1hg2h1x42fA"/>
</div>
<div class="p-8">
<span class="font-mono text-[10px] uppercase tracking-widest text-secondary mb-2 block">Internal Medicine</span>
<h3 class="font-headline text-3xl mb-1 text-primary">Prof. Marcus Wolf</h3>
<p class="text-sm font-body text-on-surface-variant mb-6">Ganzheitliche klinische Diagnostik</p>
<div class="flex items-center gap-2 mb-8 bg-surface-container/50 p-3 rounded-lg">
<span class="material-symbols-outlined text-sm text-tertiary" data-icon="event_available">event_available</span>
<span class="font-mono text-xs text-on-surface-variant">Available from Wed, 14 Oct</span>
</div>
<button class="w-full bg-primary-container text-white py-4 rounded-full font-label text-xs uppercase tracking-widest group-hover:bg-primary transition-colors">
                        Spezialist Auswählen
                    </button>
</div>
</div>
</div>
<!-- Help Section -->
<div class="mt-24 py-16 px-12 rounded-xl bg-surface-container-low flex flex-col md:flex-row items-center justify-between gap-8">
<div class="max-w-xl">
<h4 class="font-headline text-3xl text-primary mb-4">Unsicher bei der Wahl?</h4>
<p class="text-on-surface-variant leading-relaxed">Unser klinischer Kurator hilft Ihnen gerne dabei, den passenden Spezialisten für Ihre spezifischen Bedürfnisse zu finden.</p>
</div>
<button class="px-8 py-4 border border-primary/20 rounded-full font-label text-xs uppercase tracking-widest text-primary hover:bg-primary/5 transition-all">
                Kontakt Aufnehmen
            </button>
</div>
</main>
<!-- Footer -->
<footer class="w-full py-12 px-8 bg-[#F8F3EB] dark:bg-[#1A1A1F]">
<div class="flex flex-col md:flex-row justify-between items-center gap-6 max-w-7xl mx-auto">
<div class="font-headline text-lg text-[#6B1D2A]">
                The Clinical Curator
            </div>
<div class="flex gap-8">
<a class="text-[#2C2C2C]/60 dark:text-[#E2DCD2]/60 hover:text-[#6B1D2A] transition-colors font-sans Inter text-sm tracking-wide" href="#">Privacy Policy</a>
<a class="text-[#2C2C2C]/60 dark:text-[#E2DCD2]/60 hover:text-[#6B1D2A] transition-colors font-sans Inter text-sm tracking-wide" href="#">Terms of Service</a>
<a class="text-[#2C2C2C]/60 dark:text-[#E2DCD2]/60 hover:text-[#6B1D2A] transition-colors font-sans Inter text-sm tracking-wide" href="#">Clinical Standards</a>
<a class="text-[#2C2C2C]/60 dark:text-[#E2DCD2]/60 hover:text-[#6B1D2A] transition-colors font-sans Inter text-sm tracking-wide" href="#">Contact</a>
</div>
<div class="text-[#2C2C2C]/60 dark:text-[#E2DCD2]/60 font-sans Inter text-sm tracking-wide">
                © 2024 The Clinical Curator. All Rights Reserved.
            </div>
</div>
</footer>
</body></html>