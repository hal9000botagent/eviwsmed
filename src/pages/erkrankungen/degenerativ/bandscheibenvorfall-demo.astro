<td class="px-6 py-6 text-error font-bold uppercase tracking-tighter">Notfall (Sofort)</td>
</tr>
<tr class="border-b border-on-surface/5">
<td class="px-6 py-6 font-medium">Hochgradige motorische Paresen (M3)</td>
<td class="px-6 py-6 italic">Relative OP-Indikation</td>
<td class="px-6 py-6 text-primary font-bold uppercase tracking-tighter">Dringlich (24-48h)</td>
</tr>
<tr>
<td class="px-6 py-6 font-medium">Isolierter radikulärer Schmerz</td>
<td class="px-6 py-6 italic">Konservativer Therapieversuch</td>
<td class="px-6 py-6 text-tertiary font-bold uppercase tracking-tighter">Wahlweise (&gt;6 Wo)</td>
</tr>
</tbody>
</table>
</div>
</section>
</article>
<!-- Navigation between articles -->
<div class="mt-24 pt-12 border-t border-on-surface/5 flex justify-between items-center">
