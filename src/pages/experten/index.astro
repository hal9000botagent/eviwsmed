<style>
        .glass-panel {
            background: rgba(255, 255, 255, 0.4);
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
        }
        .radial-glow {
            background: radial-gradient(circle at center, rgba(107, 29, 42, 0.08) 0%, rgba(245, 240, 232, 0) 70%);
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>
<body class="bg-surface text-on-surface font-body selection:bg-primary-fixed selection:text-primary">
<!-- TopAppBar -->
<nav class="fixed top-0 w-full z-50 bg-white/40 dark:bg-stone-900/40 backdrop-blur-xl flex justify-between items-center px-6 py-4 max-w-full shadow-xl shadow-stone-900/5 backdrop-blur-2xl">
<div class="text-2xl font-serif tracking-tighter text-red-900 dark:text-red-100 uppercase">CURATOR</div>
<div class="hidden md:flex gap-8 items-center">
<a class="text-stone-500 hover:opacity-80 transition-opacity duration-400" href="#">Journal</a>
<a class="text-red-900 dark:text-red-100 font-bold hover:opacity-80 transition-opacity duration-400" href="#">Experts</a>
<a class="text-stone-500 hover:opacity-80 transition-opacity duration-400" href="#">Vault</a>
</div>
<div class="flex items-center gap-4">
<button class="bg-primary-container text-white px-6 py-2 rounded-full text-xs font-medium tracking-widest uppercase hover:opacity-90 transition-all duration-400 transform active:scale-95">Book Appointment</button>
<span class="material-symbols-outlined text-red-900 cursor-pointer" data-icon="bookmark">bookmark</span>
</div>
</nav>
<main class="pt-20 pb-32">
<!-- Editorial Hero Section -->
<section class="relative min-h-[819px] flex flex-col md:flex-row items-center px-6 md:px-24 gap-12 mb-24 overflow-hidden">
<div class="absolute inset-0 radial-glow -z-10"></div>
<div class="w-full md:w-1/2 z-10 space-y-6">
<div class="inline-block px-4 py-1 rounded-full bg-secondary-container/30 text-secondary text-[10px] tracking-[0.2em] uppercase font-bold">Clinical Leadership</div>
<h1 class="text-6xl md:text-8xl font-headline text-primary leading-tight tracking-tighter">
                    Dr. med.<br/>Elena Vance
                </h1>
<p class="text-xl md:text-2xl font-body text-on-surface-variant font-light max-w-lg leading-relaxed">
                    Chefärztin für Präventive Kardiologie &amp; Innere Medizin
                </p>
</div>
<div class="w-full md:w-1/2 relative aspect-[4/5] md:aspect-square">
<div class="absolute -inset-4 bg-primary/5 rounded-[4rem] blur-3xl"></div>
<img alt="Dr. med. Elena Vance" class="w-full h-full object-cover rounded-[3rem] shadow-2xl relative z-10 grayscale-[30%] hover:grayscale-0 transition-all duration-700" data-alt="Professional portrait of a female medical expert in a clinical setting" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDPrVyxoGJFhbSc2Jr4XxCGvHkB5HMIREqM4Y-XKH3lAOpeVDPyqJWvucuZnuTkPUghEPtcQlk6Fr54j8EgFUp1tpLSB4BCdC4_3qLEX29myqL01hU_LlMkhr_tiLhZ2mNP6LvGM2qh9wJnNRvzfmIj8X3riJ2oQsE1O0-geUM3eSnW_d1ewF5jso4etZmGROba7KLVzRp6HG9zck0q0DuEnlyp9Xvr7y5zFV5SjzyLZcMApn7ESnIZb4bKE9LbbXArkPCgPZQjq0o"/>
</div>
</section>
<!-- Content Grid -->
<div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-12 gap-8">
<!-- Bio Section -->
<section class="md:col-span-8 relative">
<div class="glass-panel p-10 md:p-16 rounded-[3rem] shadow-sm relative overflow-hidden group">
<div class="absolute top-0 right-0 p-8 opacity-10 group-hover:opacity-20 transition-opacity">
<span class="material-symbols-outlined text-8xl" data-icon="clinical_notes">clinical_notes</span>
</div>
<h2 class="text-3xl font-headline text-primary mb-8">Philosophie &amp; Expertise</h2>
<div class="space-y-6 text-lg leading-relaxed text-on-surface/80">
<p>
                            Dr. Elena Vance gilt als Pionierin der personalisierten Präventionsmedizin. Mit über zwei Jahrzehnten Erfahrung in der klinischen Kardiologie verbindet sie evidenzbasierte Protokolle mit einem tiefgreifenden Verständnis für die individuellen Lebensumstände ihrer Patienten.
                        </p>
<p>
                            Ihr Ansatz geht über die reine Symptombehandlung hinaus. Durch den Einsatz modernster bildgebender Verfahren und genetischer Marker entwickelt sie maßgeschneiderte Strategien zur Risikominimierung, bevor Krankheitsbilder manifest werden.
                        </p>
</div>
</div>
</section>
<!-- Clinical Focus -->
<section class="md:col-span-4 flex flex-col gap-6">
<div class="glass-panel p-8 rounded-[2.5rem] shadow-sm flex-1">
<h3 class="text-xs font-bold tracking-widest uppercase text-secondary mb-6">Klinische Schwerpunkte</h3>
<ul class="space-y-6">
<li class="flex items-center gap-4 group">
<div class="w-12 h-12 rounded-full bg-primary/5 flex items-center justify-center group-hover:bg-primary/10 transition-colors">
<span class="material-symbols-outlined text-primary" data-icon="favorite">favorite</span>
</div>
<span class="font-medium">Herzgesundheit</span>
</li>
<li class="flex items-center gap-4 group">
<div class="w-12 h-12 rounded-full bg-primary/5 flex items-center justify-center group-hover:bg-primary/10 transition-colors">
<span class="material-symbols-outlined text-primary" data-icon="blood_pressure">blood_pressure</span>
</div>
<span class="font-medium">Gefäßchirurgie</span>
</li>
<li class="flex items-center gap-4 group">
<div class="w-12 h-12 rounded-full bg-primary/5 flex items-center justify-center group-hover:bg-primary/10 transition-colors">
<span class="material-symbols-outlined text-primary" data-icon="query_stats">query_stats</span>
</div>
<span class="font-medium">Präventionsdiagnostik</span>
</li>
</ul>
</div>
</section>
<!-- Research & Publications -->
<section class="md:col-span-12 mt-8">
<h2 class="text-3xl font-headline text-primary mb-8 px-4">Aktuelle Forschung &amp; Publikationen</h2>
<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
<div class="glass-panel p-8 rounded-[2rem] hover:bg-white/60 transition-all duration-500">
<span class="font-mono text-[10px] text-secondary mb-2 block uppercase tracking-tighter">Journal of Cardiology · 2024</span>
<h4 class="text-lg font-bold mb-4 leading-snug">Impact of high-intensity interval training on arterial stiffness.</h4>
<div class="font-mono text-sm space-y-1 text-on-surface-variant bg-stone-100/50 p-4 rounded-xl">
<p>Cohort: n=450</p>
<p>Significance: p&lt;0.001</p>
<p>Outcome: +12% elastic improvement</p>
</div>
</div>
<div class="glass-panel p-8 rounded-[2rem] hover:bg-white/60 transition-all duration-500">
<span class="font-mono text-[10px] text-secondary mb-2 block uppercase tracking-tighter">Internal Medicine Quarterly · 2023</span>
<h4 class="text-lg font-bold mb-4 leading-snug">Lipoprotein(a) as a primary risk driver in asymptomatic adults.</h4>
<div class="font-mono text-sm space-y-1 text-on-surface-variant bg-stone-100/50 p-4 rounded-xl">
<p>Meta-analysis: n=1,200</p>
<p>Significance: p=0.004</p>
<p>Risk Ratio: 2.14 CI [1.8-2.6]</p>
</div>
</div>
<div class="glass-panel p-8 rounded-[2rem] hover:bg-white/60 transition-all duration-500">
<span class="font-mono text-[10px] text-secondary mb-2 block uppercase tracking-tighter">The Lancet · 2023</span>
<h4 class="text-lg font-bold mb-4 leading-snug">Genomic screening in preventive routine care: A pilot study.</h4>
<div class="font-mono text-sm space-y-1 text-on-surface-variant bg-stone-100/50 p-4 rounded-xl">
<p>Clinical Trial: n=85</p>
<p>Reliability: 99.8%</p>
<p>Early Detection: +34% success rate</p>
</div>
</div>
</div>
</section>
<!-- Testimonials -->
<section class="md:col-span-12 mt-12 mb-20">
<div class="flex items-center justify-between mb-8 px-4">
<h2 class="text-3xl font-headline text-primary">Patientenstimmen</h2>
<div class="flex gap-2">
<span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1;">star</span>
<span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1;">star</span>
<span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1;">star</span>
<span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1;">star</span>
<span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1;">star</span>
</div>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
<div class="glass-panel p-10 rounded-[2.5rem] relative">
<span class="absolute top-8 left-8 text-6xl text-secondary/10 font-serif">“</span>
<p class="text-xl font-light italic text-on-surface-variant relative z-10 mb-6">
                            "Dr. Vance hat sich Zeit genommen, die ich bei keinem anderen Arzt erlebt habe. Ihre Analysen sind präzise, aber ihre Empathie ist es, die den Unterschied macht."
                        </p>
<div class="flex items-center gap-4">
<div class="w-10 h-10 rounded-full bg-secondary-container/50"></div>
<span class="text-sm font-bold uppercase tracking-widest text-secondary">Marcus G., Hamburg</span>
</div>
</div>
<div class="glass-panel p-10 rounded-[2.5rem] relative border-l-4 border-secondary/20">
<span class="absolute top-8 left-8 text-6xl text-secondary/10 font-serif">“</span>
<p class="text-xl font-light italic text-on-surface-variant relative z-10 mb-6">
                            "Dank der präventiven Strategie von Dr. Vance konnten wir ein ernsthaftes Risiko erkennen, bevor es zu spät war. Eine Investition in mein Leben."
                        </p>
<div class="flex items-center gap-4">
<div class="w-10 h-10 rounded-full bg-secondary-container/50"></div>
<span class="text-sm font-bold uppercase tracking-widest text-secondary">Sarah L., Berlin</span>
</div>
</div>
</div>
</section>
</div>
</main>
